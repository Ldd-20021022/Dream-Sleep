# ============ 梦眠 (Dream-Sleep) 环境变量模板 ============
#   cp .env.example .env   → 填入真实值
#
# 密钥加载优先级:  环境变量  >  Docker Secret  >  .env 文件
#   开发: .env 文件就够了
#   生产: 用环境变量或 Docker Secret 注入，密钥不落盘

# ============================================================
#  数据库
# ============================================================
DATABASE_URL=mysql+pymysql://root:CHANGE-ME@localhost:3306/sleep_manager
DB_ROOT_PASSWORD=CHANGE-ME    # 仅 Docker 部署需要

# ============================================================
#  JWT
# ============================================================
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE-ME-生成随机64位字符串
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# ============================================================
#  AI (DeepSeek)
# ============================================================
# 从 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-YOUR-DEEPSEEK-API-KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================================
#  微信小程序
# ============================================================
WECHAT_APPID=wxYOUR-APPID
WECHAT_SECRET=YOUR-WECHAT-APPSECRET

# ============================================================
#  运行模式 (生产环境改为 true)
# ============================================================
PRODUCTION=false

# ============================================================
#  CORS (仅生产)
# ============================================================
ALLOWED_ORIGINS=https://your-domain.com
