.container { padding: 24rpx; padding-bottom: 80rpx; }

/* Period */
.period-row { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.period-chip { padding: 12rpx 24rpx; border-radius: 20rpx; background: var(--bg2); border: 1rpx solid var(--bd); font-size: 24rpx; color: var(--tx2); }
.period-chip.on { background: rgba(108,99,255,.15); border-color: var(--primary); color: var(--primary); font-weight: 600; }

/* Summary Card */
.summary-card { background: linear-gradient(135deg, rgba(108,99,255,.1), rgba(14,201,166,.05)); border-color: rgba(108,99,255,.2); }
.summary-icon { font-size: 40rpx; margin-bottom: 12rpx; }
.summary-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.summary-text { font-size: 26rpx; color: var(--tx2); line-height: 1.8; }

/* Metrics Grid */
.metrics-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.metric-item { padding: 20rpx; background: rgba(255,255,255,.03); border-radius: 14rpx; text-align: center; }
.metric-value { font-size: 40rpx; font-weight: 800; color: var(--teal); }
.metric-value.score { color: var(--primary); }
.metric-value.streak { color: #F39C12; }
.metric-label { font-size: 22rpx; color: var(--tx3); margin-top: 4rpx; }

/* Info Row */
.info-row { display: flex; gap: 16rpx; }
.info-item { flex: 1; padding: 20rpx; background: rgba(255,255,255,.03); border-radius: 14rpx; }
.info-label { font-size: 24rpx; color: var(--tx3); margin-bottom: 8rpx; }
.info-value { font-size: 36rpx; font-weight: 700; color: #fff; }
.info-hint { font-size: 20rpx; color: var(--tx3); margin-top: 4rpx; }

/* Tag Distribution */
.tag-list {}
.tag-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.tag-name { width: 120rpx; font-size: 24rpx; color: var(--tx2); text-align: right; flex-shrink: 0; }
.tag-count-bar { flex: 1; height: 12rpx; background: rgba(255,255,255,.05); border-radius: 6rpx; overflow: hidden; }
.tag-fill { height: 100%; background: var(--primary); border-radius: 6rpx; transition: width 0.5s; }
.tag-count { font-size: 22rpx; color: var(--tx3); width: 48rpx; }

/* Suggestions */
.suggestion-item { display: flex; gap: 10rpx; font-size: 26rpx; color: var(--tx2); line-height: 1.6; margin-bottom: 8rpx; }
.suggestion-dot { color: var(--primary); }

/* Actions */
.action-row { display: flex; gap: 16rpx; margin-top: 24rpx; }

.card { background: var(--bg2); border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; border: 1rpx solid var(--bd); }
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }
.page-title { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 24rpx; }
