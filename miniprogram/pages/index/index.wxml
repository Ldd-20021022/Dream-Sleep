<view class="container">
  <!-- Greeting -->
  <view class="greeting-row">
    <view>
      <view class="greeting">{{greeting}}</view>
      <view class="greeting-sub">{{dashboard ? '今天也要好好睡觉哦' : '加载中...'}}</view>
    </view>
    <view class="greeting-avatar" bindtap="goProfile">👤</view>
  </view>

  <!-- Dream World Scene -->
  <view class="dream-scene" style="background:{{dreamBg}}">
    <view wx:if="{{surprise}}" class="dream-surprise" bindtap="dismissSurprise">
      <text>📯 {{surprise}}</text>
    </view>
    <view class="dream-body">
      <view class="dream-icon">{{dreamIcon}}</view>
      <view class="dream-title">{{dreamTitle}}</view>
      <view class="dream-sub">{{dreamSub}}</view>
      <view class="dream-actions">
        <button class="btn btn-primary btn-sm" bindtap="goRecord">记录睡眠</button>
        <button class="btn btn-secondary btn-sm" style="background:rgba(255,255,255,0.08);color:#fff" bindtap="goRitual">睡前仪式</button>
      </view>
      <view class="dream-garden">
        <text>🪴{{guardian.garden.plants}}株 🌸{{guardian.garden.flowers}}朵 🌳{{guardian.garden.trees}}棵</text>
        <text wx:if="{{!guardian.garden.watered}}" style="color:var(--warn);margin-left:12rpx">⚠️未浇水</text>
        <text wx:else style="color:var(--teal);margin-left:12rpx">✅已浇水</text>
      </view>
    </view>
  </view>

  <!-- Not Logged In -->
  <view wx:if="{{notLoggedIn}}" class="card" style="text-align:center;padding:48rpx">
    <view style="font-size:64rpx;margin-bottom:16rpx">🌙</view>
    <view style="font-size:28rpx;margin-bottom:8rpx">欢迎来到梦眠</view>
    <view style="font-size:24rpx;color:var(--tx3);margin-bottom:24rpx">登录后开启你的梦境世界</view>
    <button class="btn btn-primary" bindtap="goLogin">登录 / 注册</button>
  </view>

  <!-- Score + Stats Grid -->
  <view class="grid-4" wx:if="{{dashboard}}">
    <view class="card stat-card">
      <view class="stat-label">昨晚睡眠</view>
      <view class="stat-val">{{dashboard.last_sleep ? dashboard.last_sleep.duration + 'h' : '--'}}</view>
    </view>
    <view class="card stat-card">
      <view class="stat-label">睡眠评分</view>
      <view class="stat-val" style="color:var(--teal)">{{lastScore}}</view>
      <view class="stat-sub">{{scoreLabel}}</view>
    </view>
    <view class="card stat-card">
      <view class="stat-label">连续达标</view>
      <view class="stat-val" style="color:var(--warn)">🔥{{streakDays}}<text style="font-size:22rpx;font-weight:400;color:var(--tx2)">天</text></view>
    </view>
    <view class="card stat-card">
      <view class="stat-label">守护者</view>
      <view class="stat-val" style="font-size:34rpx">Lv.{{dashboard.game ? dashboard.game.level : 1}}</view>
      <view class="stat-sub">{{dashboard.game ? dashboard.game.level_name : '入门'}}</view>
    </view>
  </view>

  <!-- Goals -->
  <view wx:if="{{goalTags.length>0}}" style="display:flex;gap:8rpx;flex-wrap:wrap;margin-bottom:20rpx;align-items:center">
    <text style="font-size:22rpx;color:var(--tx3)">🎯</text>
    <text wx:for="{{goalTags}}" wx:key="*this" class="badge">{{item}}</text>
  </view>

  <!-- Quick Actions -->
  <view class="quick-grid card" wx:if="{{dashboard}}">
    <view class="qa-item" bindtap="goRecord"><view class="qa-icon">📝</view><view class="qa-label">记录睡眠</view></view>
    <view class="qa-item" bindtap="goTasks"><view class="qa-icon">🎯</view><view class="qa-label">每日任务</view></view>
    <view class="qa-item" bindtap="goGame"><view class="qa-icon">⚔️</view><view class="qa-label">训练道场</view></view>
    <view class="qa-item" bindtap="goRitual"><view class="qa-icon">🌙</view><view class="qa-label">睡前仪式</view></view>
    <view class="qa-item" bindtap="goNoise"><view class="qa-icon">🎵</view><view class="qa-label">白噪音</view></view>
    <view class="qa-item" bindtap="goChat"><view class="qa-icon">🤖</view><view class="qa-label">AI教练</view></view>
    <view class="qa-item" bindtap="goCourses"><view class="qa-icon">📚</view><view class="qa-label">学习成长</view></view>
    <view class="qa-item" bindtap="goProfile"><view class="qa-icon">🛡️</view><view class="qa-label">守护者</view></view>
  </view>

  <!-- Daily Tip -->
  <view wx:if="{{dailyTip}}" class="card tip-card" style="margin-bottom:20rpx">
    <text style="font-size:36rpx">💡</text>
    <text style="font-size:24rpx;color:var(--tx2);flex:1">{{dailyTip}}</text>
  </view>

  <!-- AI Insight -->
  <view wx:if="{{insight}}" class="card" style="margin-bottom:20rpx;border-left:6rpx solid {{insight.priority==='critical'?'var(--danger)':insight.priority==='warning'?'var(--warn)':insight.priority==='success'?'var(--teal)':'var(--primary)'}}" bindtap="insightAction">
    <view class="section-title">{{insight.title}}</view>
    <text style="font-size:24rpx;color:var(--tx2);line-height:1.6">{{insight.body||insight.detail||insight.summary}}</text>
    <view wx:if="{{insight.action}}" style="margin-top:16rpx;font-size:24rpx;color:var(--primary)">{{insight.action.label}} →</view>
  </view>

  <!-- Program + Ritual Cards -->
  <view class="grid-2" style="margin-bottom:20rpx" wx:if="{{dashboard}}">
    <view class="card" bindtap="goCourses" style="text-align:center">
      <view style="font-size:48rpx">📅</view>
      <view style="font-size:26rpx;font-weight:600;margin:8rpx 0">21天计划</view>
      <view class="prog-bar" style="margin:12rpx 0"><view class="prog-fill" style="width:{{programPct}}%"></view></view>
      <view style="font-size:20rpx;color:var(--tx3)">{{programDay}}/21天</view>
    </view>
    <view class="card" bindtap="goRitual" style="text-align:center">
      <view style="font-size:48rpx">🌙</view>
      <view style="font-size:26rpx;font-weight:600;margin:8rpx 0">睡前仪式</view>
      <view style="font-size:20rpx;color:var(--tx3)">烦恼·呼吸·问答</view>
      <view wx:if="{{guardian.ritualStreak>0}}" style="font-size:18rpx;color:var(--teal);margin-top:8rpx">已连续{{guardian.ritualStreak}}天</view>
    </view>
  </view>

  <!-- Weekly Trend -->
  <view class="card" wx:if="{{dashboard && dashboard.trend}}">
    <view class="section-title">📈 本周趋势</view>
    <view class="mini-chart">
      <view wx:for="{{dashboard.trend}}" wx:key="date" class="chart-bar-col">
        <view class="chart-bar {{item.score >= 80 ? 'bar-green' : item.score >= 60 ? 'bar-blue' : item.score >= 40 ? 'bar-orange' : 'bar-red'}}" style="height:{{item.score > 0 ? item.score : 4}}%"></view>
        <view class="chart-date">{{item.date}}</view>
        <view class="chart-val" wx:if="{{item.score > 0}}">{{item.score}}</view>
        <view class="chart-val chart-val-zero" wx:else>--</view>
      </view>
    </view>
  </view>
</view>
