<view class="container">
  <!-- Greeting -->
  <view class="greeting-row">
    <view>
      <view class="greeting">{{greeting}}</view>
      <view class="greeting-sub">{{dashboard ? '今天也要好好睡觉哦' : '加载中...'}}</view>
    </view>
    <view class="greeting-avatar" bindtap="goProfile">👤</view>
  </view>

  <!-- 1. Dream World Scene -->
  <view class="dream-scene" style="background:{{dreamBg}}">
    <view wx:if="{{surprise}}" class="dream-surprise" bindtap="dismissSurprise">
      <text>📯 {{surprise}}</text>
    </view>
    <view class="dream-body">
      <view class="dream-icon">{{dreamIcon}}</view>
      <view class="dream-title">{{dreamTitle}}</view>
      <view class="dream-sub">{{dreamSub}}</view>
      <view class="dream-actions">
        <button class="btn btn-primary btn-sm" bindtap="goRecord">📝 记录睡眠</button>
        <button class="btn btn-secondary btn-sm" style="background:rgba(255,255,255,0.08);color:#fff" bindtap="goNoise">🎵 白噪音</button>
      </view>
      <view class="dream-garden">
        <text>🪴{{guardian.garden.plants}}株 🌸{{guardian.garden.flowers}}朵 🌳{{guardian.garden.trees}}棵</text>
        <text wx:if="{{!guardian.garden.watered}}" style="color:var(--warn);margin-left:12rpx">⚠️未浇水</text>
        <text wx:else style="color:var(--teal);margin-left:12rpx">✅已浇水</text>
      </view>
    </view>
  </view>

  <!-- Not Logged In -->
  <view wx:if="{{notLoggedIn}}" class="card" style="text-align:center;padding:48rpx">
    <view style="font-size:64rpx;margin-bottom:16rpx">🌙</view>
    <view style="font-size:28rpx;margin-bottom:8rpx">🌙 你的第一个睡眠记录</view>
    <view style="font-size:24rpx;color:var(--tx3);margin-bottom:24rpx">从今晚开始，科学改善你的睡眠</view>
    <button class="btn btn-primary" bindtap="goLogin">开始使用</button>
  </view>

  <!-- Logged in but no data -->
  <view wx:if="{{!notLoggedIn && dashboard && !dashboard.last_sleep}}" class="card" style="text-align:center;padding:48rpx;border:2rpx solid var(--primary);background:var(--primary-soft)">
    <view style="font-size:64rpx;margin-bottom:16rpx">📝</view>
    <view style="font-size:28rpx;font-weight:600;margin-bottom:8rpx">📝 昨晚睡得怎么样？</view>
    <view style="font-size:24rpx;color:var(--tx3);margin-bottom:24rpx">记录第一晚，开启你的睡眠改善之旅</view>
    <button class="btn btn-primary" bindtap="goRecord">记录昨晚睡眠</button>
  </view>

  <!-- 2. Stats Grid — 4 cards -->
  <view class="grid-4" wx:if="{{dashboard}}">
    <view class="card stat-card">
      <view class="stat-label">昨晚睡眠</view>
      <view class="stat-val">{{dashboard.last_sleep ? dashboard.last_sleep.duration + 'h' : '--'}}</view>
    </view>
    <view class="card stat-card">
      <view class="stat-label">睡眠评分</view>
      <view class="stat-val" style="color:var(--teal)">{{lastScore}}</view>
      <view class="stat-sub">{{scoreLabel}}</view>
    </view>
    <view class="card stat-card">
      <view class="stat-label">连续达标</view>
      <view class="stat-val" style="color:var(--warn)">{{streakDays >= 21 ? '🌟' : streakDays >= 7 ? '🔥🔥' : streakDays >= 3 ? '🔥' : ''}}{{streakDays}}<text style="font-size:22rpx;font-weight:400;color:var(--tx2)">天</text></view>
    </view>
    <view class="card stat-card">
      <view class="stat-label">守护者</view>
      <view class="stat-val" style="font-size:34rpx">Lv.{{dashboard.game ? dashboard.game.level : 1}}</view>
      <view class="stat-sub">{{dashboard.game ? dashboard.game.level_name : '入门'}}</view>
    </view>
  </view>

  <!-- 3. Streak Motivation — positive framing only -->
  <view wx:if="{{streakDays >= 7 && streakDays < 21}}" class="card" style="text-align:center;padding:20rpx;border:1rpx solid var(--teal);background:var(--teal-soft)">
    <text style="font-size:24rpx;color:var(--teal)">🔥🔥 连续 {{streakDays}} 天达标！已解锁「规律达人」徽章 🌟</text>
  </view>
  <view wx:elif="{{streakDays >= 21}}" class="card" style="text-align:center;padding:20rpx;border:1rpx solid var(--primary);background:var(--primary-soft)">
    <text style="font-size:24rpx;color:var(--primary)">🌟 连续 {{streakDays}} 天！你已经是睡眠大师了，继续保持</text>
  </view>
  <view wx:elif="{{streakDays > 0}}" class="card" style="text-align:center;padding:20rpx;border:1rpx solid var(--warn);background:var(--warn-soft)">
    <text style="font-size:24rpx;color:var(--warn)">🔥 连续打卡 {{streakDays}} 天，正在养成好习惯</text>
  </view>

  <!-- 4. Quick Actions — 4 core items: 记录/任务/AI教练/白噪音 -->
  <view class="quick-grid card" wx:if="{{dashboard}}">
    <view class="qa-item" bindtap="goRecord"><view class="qa-icon">📝</view><view class="qa-label">记录</view></view>
    <view wx:if="{{daysSinceJoin >= 1}}" class="qa-item" bindtap="goTasks"><view class="qa-icon">🎯</view><view class="qa-label">任务</view></view>
    <view wx:if="{{daysSinceJoin >= 2}}" class="qa-item" bindtap="goChat"><view class="qa-icon">🤖</view><view class="qa-label">AI教练</view></view>
    <view class="qa-item" bindtap="goNoise"><view class="qa-icon">🎵</view><view class="qa-label">白噪音</view></view>
    <!-- Locked for new users -->
    <view wx:if="{{daysSinceJoin < 1}}" class="qa-item" style="opacity:0.4"><view class="qa-icon">🔒</view><view class="qa-label">Day2解锁</view></view>
    <view wx:if="{{daysSinceJoin < 2}}" class="qa-item" style="opacity:0.4"><view class="qa-icon">🔒</view><view class="qa-label">Day3解锁</view></view>
  </view>

  <!-- 5. Daily Tip -->
  <view wx:if="{{dailyTip}}" class="card tip-card" style="margin-bottom:20rpx">
    <text style="font-size:36rpx">💡</text>
    <text style="font-size:24rpx;color:var(--tx2);flex:1">{{dailyTip}}</text>
  </view>
</view>
