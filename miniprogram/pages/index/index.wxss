.stat-label { font-size: 24rpx; color: var(--tx3); margin-bottom: 12rpx; }
.stat-value { font-size: 56rpx; font-weight: 700; }
.stat-value.score { color: var(--teal); }
.stat-value.streak { color: var(--warn); }
.stat-sub { font-size: 22rpx; color: var(--tx3); margin-top: 6rpx; }
.unit { font-size: 28rpx; font-weight: 400; color: var(--tx2); }

.qbtn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx;
  background: var(--hover);
  border-radius: 16rpx;
  margin: 8rpx;
}
.qic { font-size: 44rpx; }
.qlb { font-size: 24rpx; color: var(--tx2); margin-top: 8rpx; }

.tip-card {
  background: linear-gradient(135deg, rgba(108,99,255,0.08), rgba(14,201,166,0.08));
  border-color: var(--ac);
  font-size: 26rpx;
  color: var(--tx2);
}
