.ach-grid{display:flex;flex-wrap:wrap;gap:12rpx}.ach-item{width:calc(25% - 9rpx);text-align:center;padding:16rpx;border:1rpx solid var(--bd);border-radius:12rpx;opacity:0.3}.ach-item.on{opacity:1;border-color:var(--ac)}.ach-icon{font-size:40rpx}.ach-name{font-size:20rpx;margin-top:4rpx}.lb-row{display:flex;align-items:center;gap:16rpx;padding:10rpx 0;border-bottom:1rpx solid var(--bd)}.lb-rank{font-weight:700;font-size:24rpx;width:30rpx}.lb-name{flex:1;font-size:26rpx}.lb-val{font-size:24rpx;color:var(--tx3)}
