/* Resource Bar */
.resource-bar { display: flex; gap: 20rpx; justify-content: center; margin-bottom: 8rpx; }
.res-item { display: flex; align-items: center; gap: 6rpx; font-size: 28rpx; font-weight: 600; color: #fff; padding: 14rpx 28rpx; border-radius: 24rpx; }
.res-item:nth-child(1) { background: rgba(52,152,219,0.1); border: 1rpx solid rgba(52,152,219,0.2); }
.res-item:nth-child(2) { background: rgba(243,156,18,0.1); border: 1rpx solid rgba(243,156,18,0.2); }
.res-item:nth-child(3) { background: rgba(108,99,255,0.1); border: 1rpx solid rgba(108,99,255,0.15); }
.res-item.water:active { transform: scale(0.92); background: rgba(52,152,219,0.2); }
.res-item.sun:active { transform: scale(0.92); background: rgba(243,156,18,0.2); }
.res-hint { text-align: center; font-size: 20rpx; color: var(--tx3); margin-bottom: 24rpx; }

/* Animations */
.water-anim { text-align: center; font-size: 40rpx; animation: dropFloat 0.8s ease-out forwards; pointer-events: none; position: fixed; top: 200rpx; left: 50%; transform: translateX(-50%); z-index: 99; }
.sun-anim { text-align: center; font-size: 40rpx; animation: sunPulse 0.8s ease-out forwards; pointer-events: none; position: fixed; top: 200rpx; left: 50%; transform: translateX(-50%); z-index: 99; }
@keyframes dropFloat { 0% { opacity: 1; transform: translateX(-50%) translateY(0); } 100% { opacity: 0; transform: translateX(-50%) translateY(-80rpx); } }
@keyframes sunPulse { 0% { opacity: 1; transform: translateX(-50%) scale(1); } 100% { opacity: 0; transform: translateX(-50%) scale(1.8); } }

/* Plants */
.plants-grid { display: flex; flex-wrap: wrap; gap: 14rpx; justify-content: center; }
.plant-card { width: 130rpx; text-align: center; padding: 20rpx 10rpx; border-radius: 18rpx; background: rgba(255,255,255,.02); border: 1rpx solid rgba(255,255,255,.06); }
.plant-card.unlocked { border-color: rgba(94,196,186,.3); background: rgba(94,196,186,.04); animation: plantIn 0.5s ease both; }
.plant-card.locked { opacity: 0.3; filter: grayscale(1); }
@keyframes plantIn { 0% { transform: scale(0.5); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
.plant-icon { font-size: 52rpx; }
.plant-name { font-size: 20rpx; color: var(--tx2); margin-top: 6rpx; }
.plant-desc { font-size: 18rpx; color: var(--tx3); margin-top: 4rpx; }

/* Tasks */
.gtask-row { display: flex; align-items: center; gap: 12rpx; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.03); }
.gtask-icon { font-size: 26rpx; width: 40rpx; text-align: center; }
.gtask-icon:not(.done):active { transform: scale(1.3); }
.gtask-text { flex: 1; font-size: 24rpx; color: var(--tx1); }
.gtask-text.done { text-decoration: line-through; opacity: 0.4; }
.gtask-reward { font-size: 20rpx; color: var(--teal); font-weight: 600; }

/* Unlock Celebration */
.unlock-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.85); z-index: 999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.3s; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
.unlock-card { text-align: center; padding: 48rpx; animation: popUp 0.5s ease; }
@keyframes popUp { from { transform: scale(0.6); } to { transform: scale(1); } }
.unlock-sparkle { font-size: 44rpx; margin-bottom: 12rpx; }
.unlock-icon { font-size: 100rpx; margin-bottom: 12rpx; }
.unlock-title { font-size: 26rpx; color: var(--teal); margin-bottom: 6rpx; }
.unlock-name { font-size: 40rpx; font-weight: 700; color: #fff; }
.unlock-desc { font-size: 24rpx; color: var(--tx3); margin-top: 6rpx; }

.card { background: var(--card-bg); border-radius: 20rpx; padding: 22rpx; margin-bottom: 16rpx; }
.section-title { font-size: 26rpx; font-weight: 600; color: var(--tx2); margin-bottom: 12rpx; }
.page-title { font-size: 36rpx; font-weight: 600; color: #fff; margin-bottom: 24rpx; }
.empty-hint { text-align: center; color: var(--tx3); padding: 80rpx; }
