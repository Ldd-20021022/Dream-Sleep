/* Mode Select */
.mode-row { display: flex; gap: 16rpx; margin-bottom: 32rpx; }
.mode-card { flex: 1; text-align: center; padding: 32rpx 16rpx; border-radius: 20rpx; border: 1rpx solid var(--bd); background: var(--bg2); transition: all 0.3s; }
.mode-card:active { transform: scale(0.96); }
.mc-on { border-color: var(--primary, #6C63FF); background: rgba(108, 99, 255, 0.08); box-shadow: 0 0 24rpx rgba(108, 99, 255, 0.1); }
.mc-icon { font-size: 48rpx; }
.mc-name { font-size: 28rpx; font-weight: 700; color: #fff; margin: 12rpx 0 4rpx; }
.mc-desc { font-size: 22rpx; color: var(--tx3); }

/* Breathing Area */
.breathe-area {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 560rpx; position: relative;
}

/* Ripple rings behind the circle */
.breathe-area::before {
  content: ''; position: absolute; width: 260rpx; height: 260rpx; border-radius: 50%;
  border: 2rpx solid rgba(108, 99, 255, 0.2);
  animation: ripple 2s ease-out infinite;
}
.breathe-area::after {
  content: ''; position: absolute; width: 260rpx; height: 260rpx; border-radius: 50%;
  border: 1rpx solid rgba(108, 99, 255, 0.1);
  animation: ripple 2s ease-out 0.6s infinite;
}
@keyframes ripple {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(1.5); opacity: 0; }
}

.breathe-circle {
  width: 260rpx; height: 260rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transition: transform 0.15s ease, background 0.6s ease;
  box-shadow: 0 0 120rpx rgba(108, 99, 255, 0.25);
  position: relative; z-index: 1;
}

/* Phase-specific glow colors */
.breathe-circle.inhale { box-shadow: 0 0 120rpx rgba(108, 99, 255, 0.3); }
.breathe-circle.hold { box-shadow: 0 0 100rpx rgba(52, 152, 219, 0.3); }
.breathe-circle.exhale { box-shadow: 0 0 140rpx rgba(14, 201, 166, 0.25); }

.bc-inner { text-align: center; }
.bc-phase { font-size: 36rpx; font-weight: 700; color: #fff; transition: color 0.3s; }
.bc-countdown { font-size: 72rpx; font-weight: 800; color: #fff; line-height: 1.2; transition: all 0.15s; }
.bc-round { font-size: 22rpx; color: rgba(255, 255, 255, 0.5); margin-top: 8rpx; }

/* Phase indicator dots */
.phase-dots { display: flex; gap: 20rpx; margin-top: 32rpx; }
.phase-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: rgba(255, 255, 255, 0.15); transition: all 0.3s; }
.phase-dot.active { background: var(--primary, #6C63FF); box-shadow: 0 0 12rpx rgba(108, 99, 255, 0.5); transform: scale(1.3); }
.phase-dot.done { background: rgba(14, 201, 166, 0.5); }

.bc-hint { font-size: 24rpx; color: var(--tx3); margin-top: 24rpx; }

/* Difficulty badge in challenge mode */
.challenge-badge-mini {
  display: inline-block; font-size: 20rpx; color: #F39C12;
  background: rgba(243, 156, 18, 0.12); padding: 4rpx 14rpx;
  border-radius: 16rpx; margin-left: 8rpx;
}

/* Done Card */
.done-card { text-align: center; padding: 40rpx 0; animation: fadeInUp 0.5s ease; }
@keyframes fadeInUp {
  0% { transform: translateY(30rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}
.done-icon { font-size: 80rpx; margin-bottom: 16rpx; animation: popIn 0.4s ease 0.2s both; }
@keyframes popIn {
  0% { transform: scale(0); }
  80% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.done-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.done-score { font-size: 48rpx; font-weight: 800; color: var(--primary, #6C63FF); }
.done-xp { font-size: 28rpx; color: var(--success, #0EC9A6); margin: 12rpx 0; }
.done-level { font-size: 24rpx; color: #F39C12; margin-bottom: 24rpx; }

/* Idle State */
.start-wrap { text-align: center; padding: 60rpx 0; }
.idle-circle { font-size: 100rpx; animation: float 3s ease-in-out infinite; }
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}
.idle-hint { font-size: 26rpx; color: var(--tx3); margin: 20rpx 0; }

/* Info */
.info-card { background: rgba(52, 152, 219, 0.08); border-radius: 16rpx; padding: 24rpx; margin-top: 32rpx; }
.info-title { font-size: 26rpx; font-weight: 600; color: #3498DB; margin-bottom: 8rpx; }
.info-text { font-size: 24rpx; color: var(--tx2); line-height: 1.7; }

/* Shared */
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 24rpx; }
.btn { display: block; text-align: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; font-weight: 600; border: none; transition: all 0.2s; }
.btn:active { transform: scale(0.97); opacity: 0.85; }
.btn-primary { background: var(--primary, #6C63FF); color: #fff; }
