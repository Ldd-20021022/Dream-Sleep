/* Slider Row */
.slider-row { display: flex; align-items: center; padding: 16rpx 0; transition: all 0.2s; }
.slider-row:hover { background: rgba(255,255,255,.02); border-radius: 8rpx; padding-left: 8rpx; }
.sl-icon { font-size: 32rpx; width: 48rpx; text-align: center; transition: transform 0.2s; }
.slider-row:hover .sl-icon { transform: scale(1.2); }
.sl-name { font-size: 24rpx; color: var(--tx2); width: 80rpx; }
.sl-val {
  font-size: 22rpx; color: var(--tx3); width: 56rpx; text-align: right;
  font-variant-numeric: tabular-nums; font-weight: 600;
}
.sl-val.active { color: var(--primary, #6C63FF); }

/* Visualizer Bars */
.viz-bars { display: flex; gap: 4rpx; align-items: flex-end; height: 30rpx; margin: 10rpx 0; }
.viz-bar {
  flex: 1; background: var(--primary, #6C63FF); border-radius: 2rpx;
  opacity: 0.5; transition: height 0.3s;
}
.viz-bar:nth-child(odd) { animation: vizAnim 0.6s ease-in-out infinite alternate; }
.viz-bar:nth-child(even) { animation: vizAnim 0.8s ease-in-out 0.1s infinite alternate; }
@keyframes vizAnim {
  0% { height: 8rpx; }
  100% { height: 30rpx; }
}

/* Play Controls */
.play-row { display: flex; gap: 16rpx; margin-top: 20rpx; }

/* Preset Input */
.preset-input { margin-top: 16rpx; }
.preset-input input {
  width: 100%; padding: 16rpx; border-radius: 12rpx;
  border: 1rpx solid var(--bd); font-size: 24rpx;
  background: var(--bg2); box-sizing: border-box;
  transition: border-color 0.3s;
}
.preset-input input:focus { border-color: #1ABC9C; }

.save-notice {
  font-size: 22rpx; color: var(--success); text-align: center;
  padding: 8rpx; animation: fadeInUp 0.3s ease;
}
@keyframes fadeInUp {
  0% { transform: translateY(10rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}

/* Preset Cards */
.preset-card {
  padding: 16rpx 20rpx; border-radius: 12rpx; margin-bottom: 8rpx;
  background: rgba(255,255,255,.03); border: 1rpx solid var(--bd);
  transition: all 0.2s;
}
.preset-card:active { background: rgba(26,188,156,.06); border-color: rgba(26,188,156,.2); }
.ps-name { font-size: 26rpx; font-weight: 600; color: #fff; }
.ps-author { font-size: 20rpx; color: var(--tx3); margin-top: 4rpx; }

/* Playing state */
.playing .preset-card { opacity: 0.6; }
.playing .btn-primary { animation: playPulse 1.5s ease-in-out infinite; }
@keyframes playPulse {
  0%, 100% { box-shadow: 0 0 0 rgba(26,188,156,0); }
  50% { box-shadow: 0 0 32rpx rgba(26,188,156,.3); }
}

/* Shared */
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }
.card { background: var(--bg2,#1a1a2e); border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; border: 1rpx solid var(--bd,#333); }
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 24rpx; }
.btn { display: block; text-align: center; padding: 20rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 600; border: none; transition: all 0.2s; }
.btn:active { transform: scale(0.97); }
.btn-primary { background: linear-gradient(135deg, #1ABC9C, #16A085); color: #fff; }
.btn-secondary { background: rgba(255,255,255,.06); color: var(--tx2); }
.btn-sm { padding: 16rpx; font-size: 24rpx; }
