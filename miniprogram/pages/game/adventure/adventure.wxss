/* Progress */
.adv-progress { text-align: center; font-size: 24rpx; color: var(--tx2); margin-bottom: 12rpx; }
.adv-progress-bar { height: 8rpx; background: rgba(255,255,255,.1); border-radius: 4rpx; margin-bottom: 24rpx; overflow: hidden; }
.adv-progress-fill { height: 100%; background: linear-gradient(90deg, #E74C3C, #F39C12); border-radius: 4rpx; transition: width 0.8s ease; }

/* Chapter Card */
.chapter-card {
  border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx;
  border: 1rpx solid var(--bd); transition: all 0.3s;
}
.ch-unlocked { background: var(--bg2); }
.ch-unlocked:hover { border-color: rgba(231,76,96,.2); }
.ch-locked { opacity: 0.35; background: rgba(0,0,0,.1); filter: grayscale(0.5); }
.ch-header { display: flex; justify-content: space-between; margin-bottom: 8rpx; }
.ch-num { font-size: 24rpx; font-weight: 700; color: var(--primary); }
.ch-boss {
  font-size: 22rpx; color: #E74C3C; background: rgba(231,76,96,.1);
  padding: 2rpx 12rpx; border-radius: 12rpx; border: 1rpx solid rgba(231,76,96,.15);
  animation: bossGlow 2s ease-in-out infinite;
}
@keyframes bossGlow {
  0%, 100% { box-shadow: 0 0 0 rgba(231,76,96,0); }
  50% { box-shadow: 0 0 12rpx rgba(231,76,96,.2); }
}
.ch-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.ch-story { font-size: 24rpx; color: var(--tx2); line-height: 1.7; white-space: pre-line; }
.ch-req { font-size: 22rpx; color: var(--tx3); margin-top: 12rpx; padding: 8rpx 16rpx; background: rgba(255,255,255,.03); border-radius: 8rpx; }

/* Battle Overlay */
.battle-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,.9); display: flex; align-items: center;
  justify-content: center; z-index: 999;
  animation: fadeIn 0.3s ease;
}
@keyframes fadeIn { 0% { opacity: 0; } 100% { opacity: 1; } }

.battle-box { padding: 40rpx; text-align: center; width: 80%; }

/* Boss HP Bar */
.battle-hp-bar {
  height: 24rpx; background: rgba(255,255,255,.08);
  border-radius: 12rpx; overflow: hidden; margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,.1);
}
.battle-hp-fill {
  height: 100%; background: linear-gradient(90deg, #E74C3C, #F39C12);
  border-radius: 12rpx; transition: width 0.8s cubic-bezier(0.4,0,0.2,1);
  box-shadow: inset 0 0 12rpx rgba(255,255,255,.2);
}
.battle-hp-fill.danger {
  background: linear-gradient(90deg, #c0392b, #E74C3C);
  animation: hpPulse 0.5s ease-in-out infinite;
}
@keyframes hpPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.6; }
}

.battle-hp-text { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 24rpx; }

/* Battle Text Animation */
.battle-text {
  font-size: 32rpx; font-weight: 700; color: var(--primary, #6C63FF);
  animation: textFlash 0.6s ease;
  min-height: 48rpx;
}
@keyframes textFlash {
  0% { transform: scale(0.8); opacity: 0; }
  50% { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); opacity: 1; }
}

/* Battle emoji splash */
.battle-emoji-splash {
  position: absolute; font-size: 48rpx;
  animation: emojiUp 0.8s ease forwards; pointer-events: none;
}
@keyframes emojiUp {
  0% { transform: translateY(0) scale(0); opacity: 1; }
  100% { transform: translateY(-100rpx) scale(1.5); opacity: 0; }
}

/* Shared */
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 24rpx; }
.empty-hint { text-align: center; color: var(--tx3); padding: 80rpx; font-size: 26rpx; }
.btn { display: block; text-align: center; padding: 20rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 600; border: none; transition: all 0.2s; }
.btn:active { transform: scale(0.97); }
.btn-primary { background: linear-gradient(135deg, #E74C3C, #c0392b); color: #fff; }
.btn-sm { padding: 16rpx; font-size: 24rpx; }
