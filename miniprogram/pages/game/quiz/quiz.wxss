/* Progress */
.progress-text { text-align: center; font-size: 24rpx; color: var(--tx3); margin-bottom: 10rpx; }
.progress-bar { height: 6rpx; background: rgba(255,255,255,.1); border-radius: 3rpx; margin-bottom: 24rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #F39C12, #E74C3C); border-radius: 3rpx; transition: width 0.3s; }

/* Question Card */
.q-card { margin-bottom: 24rpx; animation: slideInQ 0.3s ease; }
@keyframes slideInQ {
  0% { transform: translateX(40rpx); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}
.q-num { font-size: 24rpx; color: #F39C12; font-weight: 700; margin-bottom: 8rpx; }
.q-text { font-size: 32rpx; font-weight: 600; color: #fff; line-height: 1.5; margin-bottom: 24rpx; }

/* Options */
.q-opt {
  display: flex; align-items: flex-start; gap: 16rpx;
  padding: 20rpx; border-radius: 16rpx; margin-bottom: 12rpx;
  border: 1rpx solid var(--bd); background: rgba(255,255,255,.02);
  transition: all 0.25s;
}
.q-opt:active { transform: scale(0.98); background: rgba(255,255,255,.06); }
.q-opt-sel { border-color: #F39C12; background: rgba(243,156,18,.08); box-shadow: 0 0 20rpx rgba(243,156,18,.08); }
.q-opt-correct { border-color: #2ECC71; background: rgba(46,204,113,.08); animation: correctPulse 0.5s ease; }
.q-opt-wrong { border-color: #E74C3C; background: rgba(231,76,96,.06); animation: shake 0.5s ease; }
@keyframes correctPulse {
  0%, 100% { box-shadow: 0 0 0 rgba(46,204,113,0); }
  50% { box-shadow: 0 0 30rpx rgba(46,204,113,.3); }
}
@keyframes shake {
  0%, 100% { transform: translateX(0); }
  20% { transform: translateX(-10rpx); }
  40% { transform: translateX(10rpx); }
  60% { transform: translateX(-6rpx); }
  80% { transform: translateX(6rpx); }
}

.q-opt-letter {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: 700;
  background: rgba(255,255,255,.06); color: var(--tx2); flex-shrink: 0;
}
.q-opt-sel .q-opt-letter { background: #F39C12; color: #fff; }
.q-opt-text { font-size: 26rpx; color: var(--tx1,#eee); line-height: 1.5; padding-top: 10rpx; }

/* Navigation */
.q-nav { display: flex; gap: 16rpx; justify-content: center; margin-top: 8rpx; }

/* Results */
.results-section { text-align: center; }
.score-big {
  font-size: 80rpx; font-weight: 800;
  background: linear-gradient(135deg, #F39C12, #6C63FF);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: scorePop 0.5s ease 0.2s both;
}
@keyframes scorePop {
  0% { transform: scale(0); }
  80% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.result-item {
  display: flex; gap: 16rpx; padding: 16rpx; border-radius: 12rpx;
  margin-top: 12rpx; text-align: left;
}
.rc-correct { background: rgba(46,204,113,.06); }
.rc-wrong { background: rgba(231,76,96,.06); }
.ri-status { font-size: 24rpx; flex-shrink: 0; }
.ri-explain { font-size: 24rpx; color: var(--tx2); line-height: 1.6; }

/* Fragments display */
.fragments-earned {
  display: inline-flex; align-items: center; gap: 8rpx;
  margin: 12rpx 0; padding: 8rpx 24rpx;
  background: rgba(243,156,18,.1); border-radius: 24rpx;
  font-size: 24rpx; color: #F39C12;
}

/* Shared */
.done-icon { font-size: 64rpx; margin-bottom: 8rpx; animation: popIn 0.4s ease 0.1s both; }
@keyframes popIn {
  0% { transform: scale(0); }
  80% { transform: scale(1.2); }
  100% { transform: scale(1); }
}
.done-title { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.done-xp { font-size: 24rpx; color: var(--success,#0EC9A6); margin: 12rpx 0; }
.empty-hint { text-align: center; color: var(--tx3); padding: 80rpx 0; font-size: 26rpx; }
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 24rpx; }
.btn { display: block; text-align: center; padding: 20rpx 32rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 600; border: none; transition: all 0.2s; }
.btn:active { transform: scale(0.97); }
.btn-primary { background: var(--primary,#6C63FF); color: #fff; }
.btn-secondary { background: rgba(255,255,255,.06); color: var(--tx2); }
.btn-sm { padding: 14rpx 24rpx; font-size: 24rpx; }
