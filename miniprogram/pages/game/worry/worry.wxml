<view class="container">
  <view class="page-title">💥 烦恼粉碎机</view>

  <!-- Write Phase -->
  <view wx:if="{{phase==='write'}}" class="write-section">
    <view class="w-hint">💭 把让你烦恼的事情写下来...\n写出来的烦恼就已经失去了一半的力量</view>
    <input class="w-input" placeholder="输入一个烦恼，然后按+" value="{{input}}" bindinput="onInput" maxlength="50" confirm-type="done" bindconfirm="addWorry"/>
    <button class="btn btn-secondary btn-sm" bindtap="addWorry" style="margin:12rpx 0">+ 添加烦恼</button>
    <view wx:for="{{worries}}" wx:key="*this" class="w-item">💭 {{item}}</view>
    <button wx:if="{{worries.length > 0}}" class="btn btn-primary" bindtap="startCrush" style="margin-top:24rpx">💥 粉碎全部烦恼 ({{worries.length}}个)</button>
  </view>

  <!-- Crush Phase -->
  <view wx:if="{{phase==='crush'}}" class="crush-area">
    <view class="c-hint">👆 点击泡泡戳破它们！</view>
    <view wx:for="{{bubbles}}" wx:key="id" class="bubble {{item.popped?'bubble-pop':''}}"
          style="left:{{item.x}};top:{{item.y}};transform:scale({{item.size}});animation-delay:{{item.delay}}"
          data-id="{{item.id}}" bindtap="popBubble">
      <view class="bubble-text">{{item.text}}</view>
    </view>
    <view class="c-counter">已粉碎 {{popped}}/{{bubbles.length}}</view>
  </view>

  <!-- Done -->
  <view wx:if="{{phase==='done'}}" class="done-section">
    <view class="done-icon">🎉</view>
    <view class="done-title">烦恼已清空！</view>
    <view class="done-xp">+{{xpEarned}} XP</view>
    <view class="done-hint">深呼吸，让自己放松下来</view>
    <button class="btn btn-primary" bindtap="reset">再写一轮</button>
  </view>

  <view class="info-card" style="margin-top:32rpx">
    <view class="info-title">💡 CBT-I 担忧时间技术</view>
    <view class="info-text">把抽象的焦虑写下来、具象化、然后"消灭"它——这是认知行为疗法中的经典技术。你会发现，写出来的烦恼往往比在脑子里打转时要小得多。</view>
  </view>
</view>
