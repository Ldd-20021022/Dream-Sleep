.write-section { padding: 20rpx 0; }
.w-hint { font-size: 26rpx; color: var(--tx2); line-height: 1.6; margin-bottom: 20rpx; white-space: pre-line; }
.w-input { width: 100%; padding: 20rpx; border-radius: 16rpx; border: 1rpx solid var(--bd); font-size: 26rpx; background: var(--bg2); box-sizing: border-box; transition: border-color 0.3s; }
.w-input:focus { border-color: #9B59B6; }
.w-item {
  font-size: 26rpx; color: var(--tx1); padding: 14rpx 20rpx; margin-top: 8rpx;
  background: rgba(155, 89, 182, 0.08); border-radius: 12rpx;
  animation: slideIn 0.3s ease;
}
@keyframes slideIn {
  0% { transform: translateX(-30rpx); opacity: 0; }
  100% { transform: translateX(0); opacity: 1; }
}

/* Crush Area */
.crush-area { position: relative; height: 600rpx; background: radial-gradient(circle, rgba(155, 89, 182, 0.08), rgba(0, 0, 0, 0.3)); border-radius: 24rpx; overflow: hidden; }
.c-hint { text-align: center; font-size: 24rpx; color: var(--tx3); padding: 20rpx; position: relative; z-index: 1; }

/* Bubble */
.bubble {
  position: absolute; padding: 24rpx 32rpx; border-radius: 50%;
  background: linear-gradient(135deg, rgba(155, 89, 182, 0.35), rgba(155, 89, 182, 0.12));
  border: 1rpx solid rgba(155, 89, 182, 0.3);
  animation: floatBubble 3s ease-in-out infinite;
  text-align: center; max-width: 240rpx;
  transition: transform 0.3s, opacity 0.3s;
  box-shadow: 0 0 30rpx rgba(155, 89, 182, 0.1);
}
.bubble:active { transform: scale(1.1) !important; }
.bubble-pop { animation: popBurst 0.4s forwards !important; pointer-events: none; }
.bubble-text { font-size: 24rpx; color: #fff; word-break: break-all; line-height: 1.4; }

/* Particle burst on pop */
.bubble-pop::after {
  content: '';
  position: absolute; top: 50%; left: 50%;
  width: 10rpx; height: 10rpx; border-radius: 50%;
  background: rgba(155, 89, 182, 0.8);
  animation: particleSpread 0.5s forwards;
  box-shadow:
    30rpx 0 0 rgba(255,255,255,0.3),
    -30rpx 0 0 rgba(155,89,182,0.3),
    0 30rpx 0 rgba(255,255,255,0.3),
    0 -30rpx 0 rgba(155,89,182,0.3),
    20rpx 20rpx 0 rgba(255,255,255,0.2),
    -20rpx -20rpx 0 rgba(155,89,182,0.2);
}
@keyframes particleSpread {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(3); opacity: 0; }
}

@keyframes floatBubble {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-25rpx); }
}
@keyframes popBurst {
  0% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.4); opacity: 0.4; }
  100% { transform: scale(0); opacity: 0; }
}

.c-counter { position: absolute; bottom: 24rpx; left: 50%; transform: translateX(-50%); font-size: 24rpx; color: var(--tx3); background: rgba(0, 0, 0, 0.5); padding: 10rpx 28rpx; border-radius: 24rpx; backdrop-filter: blur(10rpx); }

/* Done */
.done-section { text-align: center; padding: 40rpx 0; animation: fadeInUp 0.5s ease; }
@keyframes fadeInUp {
  0% { transform: translateY(30rpx); opacity: 0; }
  100% { transform: translateY(0); opacity: 1; }
}
.done-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.done-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.done-xp { font-size: 28rpx; color: var(--success); margin: 12rpx 0; }
.done-hint { font-size: 24rpx; color: var(--tx3); margin-bottom: 24rpx; }

/* Info */
.info-card { background: rgba(155, 89, 182, 0.08); border-radius: 16rpx; padding: 24rpx; }
.info-title { font-size: 26rpx; font-weight: 600; color: #9B59B6; margin-bottom: 8rpx; }
.info-text { font-size: 24rpx; color: var(--tx2); line-height: 1.7; }

/* Shared */
.page-title { font-size: 36rpx; font-weight: 700; color: #fff; margin-bottom: 24rpx; }
.btn { display: block; text-align: center; padding: 20rpx; border-radius: 16rpx; font-size: 26rpx; font-weight: 600; border: none; transition: all 0.2s; }
.btn:active { transform: scale(0.97); }
.btn-primary { background: var(--primary, #6C63FF); color: #fff; }
.btn-secondary { background: rgba(255, 255, 255, 0.06); color: var(--tx2); }
.btn-sm { padding: 14rpx 20rpx; font-size: 24rpx; }
