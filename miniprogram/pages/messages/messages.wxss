.container { padding: 24rpx; }
.page-title { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 24rpx; }
.empty { text-align: center; padding: 80rpx 0; color: var(--tx3); }
.empty-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.empty-text { font-size: 28rpx; color: var(--tx2); }
.empty-hint { font-size: 24rpx; color: var(--tx3); margin-top: 8rpx; }

/* Conversations */
.conv-item { display: flex; align-items: center; gap: 14rpx; padding: 20rpx 16rpx; border-bottom: 1rpx solid rgba(255,255,255,.03); }
.conv-avatar { width: 60rpx; height: 60rpx; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: #fff; font-weight: 700; }
.conv-body { flex: 1; }
.conv-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6rpx; }
.conv-name { font-size: 28rpx; font-weight: 600; color: #fff; }
.conv-time { font-size: 20rpx; color: var(--tx3); }
.conv-msg { font-size: 24rpx; color: var(--tx3); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.conv-badge { min-width: 32rpx; height: 32rpx; line-height: 32rpx; text-align: center; border-radius: 16rpx; background: #E74C3C; color: #fff; font-size: 20rpx; padding: 0 8rpx; }

/* Chat Window */
.chat-window { display: flex; flex-direction: column; height: 100vh; }
.chat-header { display: flex; justify-content: space-between; align-items: center; padding: 20rpx 24rpx; border-bottom: 1rpx solid var(--bd); background: var(--bg); }
.chat-back { font-size: 26rpx; color: var(--primary); }
.chat-name { font-size: 30rpx; font-weight: 700; color: #fff; }
.chat-body { flex: 1; padding: 20rpx 24rpx; overflow-y: auto; }
.chat-empty { text-align: center; color: var(--tx3); padding: 120rpx 0; }
.chat-bubble { margin-bottom: 20rpx; display: flex; flex-direction: column; }
.chat-bubble.from { align-items: flex-start; }
.chat-bubble.to { align-items: flex-end; }
.bubble-content { max-width: 75%; padding: 16rpx 22rpx; border-radius: 20rpx; font-size: 28rpx; line-height: 1.5; word-break: break-all; }
.chat-bubble.from .bubble-content { background: var(--bg2); color: #fff; border-top-left-radius: 4rpx; }
.chat-bubble.to .bubble-content { background: var(--primary); color: #fff; border-top-right-radius: 4rpx; }
.bubble-time { font-size: 20rpx; color: var(--tx3); margin-top: 4rpx; padding: 0 8rpx; }
.chat-input-row { display: flex; gap: 10rpx; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid var(--bd); background: var(--bg); }
.chat-input { flex: 1; padding: 14rpx 18rpx; background: var(--bg2); border-radius: 24rpx; font-size: 26rpx; color: #fff; border: 1rpx solid var(--bd); }
.chat-send { padding: 14rpx 28rpx; background: var(--primary); color: #fff; border-radius: 24rpx; font-size: 24rpx; border: none; }

/* Voice */
.voice-btn { width: 56rpx; height: 56rpx; border-radius: 50%; background: var(--bg2); border: 1rpx solid var(--bd); display: flex; align-items: center; justify-content: center; font-size: 28rpx; flex-shrink: 0; }
.recording-bar { flex: 1; display: flex; align-items: center; gap: 10rpx; padding: 14rpx 18rpx; background: rgba(231,76,60,.1); border: 1rpx solid rgba(231,76,60,.3); border-radius: 24rpx; color: #E74C3C; font-size: 24rpx; }
.recording-dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #E74C3C; animation: pulse 0.8s ease infinite; }
@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
.bubble-voice { display: flex; align-items: center; gap: 8rpx; padding: 16rpx 22rpx; background: var(--primary); border-radius: 20rpx; color: #fff; font-size: 26rpx; }
.voice-icon { font-size: 28rpx; }
.voice-dur { font-size: 22rpx; opacity: 0.8; }
.bubble-image { max-width: 240rpx; border-radius: 16rpx; }
.read-check { font-size: 16rpx; color: #2ECC71; margin-left: 4rpx; }
.img-pick-btn { width: 56rpx; height: 56rpx; border-radius: 50%; background: var(--bg2); border: 1rpx solid var(--bd); display: flex; align-items: center; justify-content: center; font-size: 24rpx; flex-shrink: 0; }
.send-img-preview { position: relative; display: inline-block; margin-right: 8rpx; }
.send-img-preview image { width: 80rpx; height: 80rpx; border-radius: 8rpx; }
.send-img-remove { position: absolute; top: -8rpx; right: -8rpx; background: #E74C3C; color: #fff; width: 32rpx; height: 32rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18rpx; }
