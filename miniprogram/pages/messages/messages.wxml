<view class="container">
  <!-- Conversation List -->
  <view wx:if="{{!chatUser}}">
    <view class="page-title">💬 私信</view>
    <view wx:if="{{loading}}" class="empty">加载中...</view>
    <view wx:elif="{{conversations.length===0}}" class="empty">
      <view class="empty-icon">💬</view>
      <view class="empty-text">暂无会话</view>
      <view class="empty-hint">在社区点击用户头像即可发起私信</view>
    </view>
    <view wx:for="{{conversations}}" wx:key="user_id" class="conv-item" data-user-id="{{item.user_id}}" data-nickname="{{item.nickname}}" bindtap="openChat">
      <view class="conv-avatar">{{item.nickname ? item.nickname[0] : '?'}}</view>
      <view class="conv-body">
        <view class="conv-top">
          <view class="conv-name">{{item.nickname}}</view>
          <view class="conv-time">{{item.last_time ? item.last_time.slice(0,10) : ''}}</view>
        </view>
        <view class="conv-msg">{{item.last_message || '暂无消息'}}</view>
      </view>
      <view wx:if="{{item.unread > 0}}" class="conv-badge">{{item.unread}}</view>
    </view>
  </view>

  <!-- Chat Window -->
  <view wx:else class="chat-window">
    <view class="chat-header">
      <view class="chat-back" bindtap="closeChat">← 返回</view>
      <view class="chat-name">{{chatUser.nickname}}</view>
      <view></view>
    </view>

    <scroll-view scroll-y class="chat-body" scroll-into-view="chatBottom">
      <view wx:if="{{chatMessages.length===0}}" class="chat-empty">开始聊天吧~</view>
      <view wx:for="{{chatMessages}}" wx:key="id" class="chat-bubble {{item.sender_id === chatUser.id ? 'from' : 'to'}}">
        <view wx:if="{{item.voice_url}}" class="bubble-voice" data-url="{{item.voice_url}}" bindtap="playVoice">
          <text class="voice-icon">🔊</text>
          <text class="voice-dur">{{item.voice_duration || 0}}s</text>
        </view>
        <image wx:elif="{{item.image_url}}" src="{{item.image_url}}" mode="widthFix" class="bubble-image"/>
        <view wx:else class="bubble-content">{{item.content}}</view>
        <view class="bubble-time">
          {{item.created_at ? item.created_at.slice(11,16) : ''}}
          <text wx:if="{{item.sender_id !== chatUser.id && item.read_at}}" class="read-check">✓✓</text>
        </view>
      </view>
      <view id="chatBottom"></view>
    </scroll-view>

    <view class="chat-input-row">
      <view wx:if="{{sendImage}}" class="send-img-preview">
        <image src="{{sendImage}}" mode="widthFix"/>
        <view class="send-img-remove" bindtap="removeChatImage">✕</view>
      </view>
      <view wx:if="{{!recording}}" class="img-pick-btn" bindtap="chooseChatImage">🖼️</view>
      <view wx:if="{{!recording}}" class="voice-btn" bindtouchstart="startRecord" bindtouchend="stopRecord">🎤</view>
      <view wx:else class="recording-bar" bindtap="stopRecord">
        <view class="recording-dot"></view>
        <text>录音中 {{recordTime}}s（点击停止）</text>
      </view>
      <input wx:if="{{!recording}}" class="chat-input" placeholder="输入消息..." value="{{chatInput}}" bindinput="onChatInput" confirm-type="send" bindconfirm="sendMessage"/>
      <button wx:if="{{!recording}}" class="chat-send" bindtap="sendMessage" loading="{{sending}}">发送</button>
    </view>
  </view>
</view>
