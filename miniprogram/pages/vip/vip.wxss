/* Status bar */
.vip-status { display: flex; align-items: center; gap: 20rpx; padding: 28rpx 32rpx; border-radius: 20rpx; margin-bottom: 28rpx; }
.vs-free { background: rgba(255,255,255,0.03); border: 1rpx solid rgba(255,255,255,0.06); }
.vs-premium { background: linear-gradient(135deg, rgba(240,176,80,0.1), rgba(139,156,247,0.08)); border: 1rpx solid rgba(240,176,80,0.2); }
.vs-icon { font-size: 56rpx; }
.vs-info { flex: 1; }
.vs-name { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 4rpx; }
.vs-sub { font-size: 22rpx; color: var(--tx3); }

/* Billing switch */
.bill-switch { display: flex; justify-content: center; gap: 0; background: rgba(255,255,255,0.04); border-radius: 32rpx; padding: 6rpx; margin-bottom: 28rpx; width: fit-content; margin-left: auto; margin-right: auto; }
.bs-label { padding: 14rpx 40rpx; border-radius: 28rpx; font-size: 26rpx; color: var(--tx3); transition: all 0.2s; }
.bs-on { background: var(--primary); color: #fff; font-weight: 600; }
.bs-hover { opacity: 0.8; }
.bs-pop { animation: bsPop 0.3s ease; }
@keyframes bsPop { 0%{transform:scale(1)} 50%{transform:scale(0.95)} 100%{transform:scale(1)} }
.bs-save { font-size: 20rpx; color: var(--warn); margin-left: 6rpx; }

/* Pricing cards */
.vp-cards { display: flex; gap: 12rpx; align-items: center; }
.vp-card { flex: 1; background: rgba(255,255,255,0.02); border: 1rpx solid rgba(255,255,255,0.04); border-radius: 20rpx; padding: 20rpx 14rpx; text-align: center; position: relative; transition: all 0.3s; display: flex; flex-direction: column; opacity: 0.7; transform: scale(0.94); }
.vp-card.vp-recommend { opacity: 1; transform: scale(1); background: rgba(139,156,247,0.06); border-color: rgba(139,156,247,0.25); padding: 28rpx 18rpx; box-shadow: 0 8rpx 40rpx rgba(139,156,247,0.12); z-index: 2; }
.vp-card.vp-current { opacity: 1; transform: scale(0.94); border-color: var(--primary); background: rgba(139,156,247,0.06); }
.vp-card.vp-recommend.vp-current { transform: scale(1); box-shadow: 0 8rpx 40rpx rgba(240,176,80,0.15); border-color: rgba(240,176,80,0.4); }
.vp-badge { position: absolute; top: -16rpx; left: 50%; transform: translateX(-50%); background: linear-gradient(135deg, var(--warn), #e09030); color: #fff; padding: 4rpx 20rpx; border-radius: 16rpx; font-size: 20rpx; font-weight: 600; }
.vp-tier { font-size: 36rpx; margin-bottom: 6rpx; }
.vp-recommend .vp-tier { font-size: 52rpx; }
.vp-name { font-size: 22rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.vp-recommend .vp-name { font-size: 30rpx; font-weight: 800; }
.vp-price { margin-bottom: 14rpx; }
.vp-num { font-size: 36rpx; font-weight: 800; color: #fff; }
.vp-recommend .vp-num { font-size: 52rpx; }
.vp-dur { font-size: 18rpx; color: var(--tx3); }
.vp-recommend .vp-dur { font-size: 24rpx; }
.vp-feats { text-align: left; margin-bottom: 12rpx; flex: 1; }
.vp-feat { font-size: 18rpx; color: var(--tx2); padding: 3rpx 0; }
.vp-recommend .vp-feat { font-size: 22rpx; padding: 5rpx 0; }
.vp-na { color: var(--tx3); opacity: 0.5; }
.vp-btn-wrap { margin-top: auto; }
.vp-btn { width: 100%; padding: 14rpx; border-radius: 16rpx; font-size: 22rpx; font-weight: 600; border: none; text-align: center; }
.vp-recommend .vp-btn { padding: 20rpx; font-size: 28rpx; }
.vp-btn-curr { background: rgba(255,255,255,0.05); color: var(--tx3); }
.vp-btn-up { background: linear-gradient(135deg, var(--primary), #7a8ae0); color: #fff; box-shadow: 0 4rpx 16rpx rgba(139,156,247,0.2); }

/* Compare */
.vcmp-hd { display: flex; justify-content: space-between; align-items: center; font-size: 28rpx; font-weight: 600; color: var(--tx2); padding: 8rpx 0; }
.vcmp-arrow { font-size: 22rpx; color: var(--tx3); }
.vcmp-body { margin-top: 16rpx; }
.vcmp-row { display: flex; padding: 12rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); font-size: 22rpx; }
.vcmp-row-hd { color: var(--tx3); font-weight: 600; }
.vcmp-cell { flex: 1; text-align: center; color: var(--tx2); }
.vcmp-name { flex: 1.5; text-align: left; }
.vcmp-hl { color: var(--ac); font-weight: 600; }

/* Orders */
.vp-order { display: flex; justify-content: space-between; padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,0.04); font-size: 24rpx; color: var(--tx2); }
.vp-order-status { font-size: 20rpx; }
.order-paid { color: var(--suc); }
.order-pending { color: var(--warn); }
.order-refunded { color: var(--tx3); }

/* Pay modal */
.modal-pay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.8); z-index: 2000; display: flex; align-items: center; justify-content: center; }
.modal-pay-card { background: var(--card-bg); border-radius: 24rpx; padding: 48rpx 40rpx; width: 560rpx; max-width: 90vw; text-align: center; border: 1rpx solid var(--bd); }
.pay-modal-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.pay-modal-title { font-size: 32rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.pay-modal-price { font-size: 56rpx; font-weight: 800; color: var(--ac); margin-bottom: 8rpx; }
.pay-modal-no { font-size: 22rpx; color: var(--tx3); margin-bottom: 24rpx; }
.pay-confirm-btn { width: 100%; margin-bottom: 12rpx; }
.pay-cancel { width: 100%; }
