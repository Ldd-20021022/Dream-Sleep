.label { display: block; margin-bottom: 12rpx; font-size: 26rpx; color: var(--tx2); }
.pwd-eye { position: absolute; right: 20rpx; top: 56rpx; font-size: 36rpx; z-index: 2; }
.err-box { color: var(--err); font-size: 24rpx; margin-top: 16rpx; padding: 16rpx; background: rgba(231,76,60,0.1); border-radius: 8rpx; }
.pw-bar-wrap { display: flex; align-items: center; margin-top: 8rpx; margin-bottom: 8rpx; }
.pw-bar-fill { height: 6rpx; border-radius: 3rpx; transition: all 0.3s; min-width: 0; }
