<view class="container" style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh">
  <view style="text-align:center;margin-bottom:60rpx">
    <view style="font-size:96rpx;margin-bottom:16rpx">🌙</view>
    <view style="font-size:48rpx;font-weight:700;background:linear-gradient(135deg,var(--ac),var(--teal));-webkit-background-clip:text;-webkit-text-fill-color:transparent">梦眠</view>
    <view style="font-size:28rpx;color:var(--tx3);margin-top:8rpx">{{isRegister?'创建账号':'AI智能睡眠管理'}}</view>
  </view>

  <view style="width:100%;max-width:600rpx">
    <!-- Login -->
    <view class="card" wx:if="{{!isRegister}}">
      <view class="form-group"><text class="label">用户名</text><input class="input" placeholder="请输入用户名" value="{{username}}" bindinput="setUname"/></view>
      <view class="form-group" style="position:relative">
        <text class="label">密码</text>
        <input class="input" type="{{showPwd?'text':'password'}}" placeholder="请输入密码" value="{{password}}" bindinput="setPwd"/>
        <view class="pwd-eye" bindtap="togglePwd">{{showPwd?'🙈':'👁'}}</view>
      </view>
      <view wx:if="{{error}}" class="err-box">{{error}}<text wx:if="{{lockCountdown>0}}"> ({{lockCountdown}}秒后重试)</text></view>
      <button class="btn btn-primary" style="width:100%;margin-top:24rpx" bindtap="handleLogin" loading="{{loading}}" disabled="{{lockCountdown>0}}">{{loading?'登录中...':lockCountdown>0?lockCountdown+'秒后重试':'登录'}}</button>
      <view style="text-align:center;margin-top:20rpx;font-size:24rpx;color:var(--tx3)">还没有账号？<text style="color:var(--ac)" bindtap="switchToRegister">立即注册</text></view>
    </view>

    <!-- Register -->
    <view class="card" wx:if="{{isRegister}}">
      <view class="form-group"><text class="label">用户名</text><input class="input" placeholder="2-20个字符" value="{{regUser}}" bindinput="setRegUser" maxlength="20"/></view>
      <view class="form-group"><text class="label">邮箱</text><input class="input" type="text" placeholder="用于找回密码" value="{{regEmail}}" bindinput="setRegEmail"/></view>
      <view class="form-group" style="position:relative">
        <text class="label">密码（字母+数字，6位以上）</text>
        <input class="input" type="{{showPwdReg?'text':'password'}}" placeholder="至少6位" value="{{regPwd}}" bindinput="setRegPwd"/>
        <view class="pwd-eye" bindtap="togglePwdReg">{{showPwdReg?'🙈':'👁'}}</view>
      </view>
      <view wx:if="{{regPwd}}" class="pw-bar-wrap"><view class="pw-bar-fill" style="width:{{pwStrength*25}}%;background:{{pwStrength<=1?'var(--err)':pwStrength<=2?'var(--warn)':pwStrength<=3?'var(--teal)':'var(--suc)'}}"></view><text style="font-size:22rpx;margin-left:12rpx;color:var(--tx3)">{{['弱','弱','中','强','很强'][pwStrength]}}</text></view>
      <view class="form-group"><text class="label">昵称</text><input class="input" placeholder="显示名称" value="{{regNick}}" bindinput="setRegNick"/></view>
      <view wx:if="{{regErr}}" class="err-box">{{regErr}}</view>
      <button class="btn btn-primary" style="width:100%;margin-top:24rpx" bindtap="handleRegister" loading="{{regLoading}}" disabled="{{!regValid}}">{{regLoading?'注册中...':'注册'}}</button>
      <view style="text-align:center;margin-top:20rpx;font-size:24rpx;color:var(--tx3)">已有账号？<text style="color:var(--ac)" bindtap="switchToLogin">返回登录</text></view>
    </view>
  </view>
</view>
