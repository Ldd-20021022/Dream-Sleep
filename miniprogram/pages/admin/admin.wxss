.container { padding: 24rpx; }
.page-title { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 24rpx; }
.stats-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; margin-bottom: 20rpx; }
.stat-box { padding: 24rpx; background: var(--bg2); border-radius: 14rpx; text-align: center; border: 1rpx solid var(--bd); }
.stat-box.warn { border-color: rgba(231,76,60,.3); background: rgba(231,76,60,.06); }
.stat-num { font-size: 40rpx; font-weight: 800; color: #fff; }
.stat-label { font-size: 22rpx; color: var(--tx3); margin-top: 4rpx; }
.card { background: var(--bg2); border-radius: 20rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx; border: 1rpx solid var(--bd); }
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.empty { text-align: center; color: var(--tx3); padding: 40rpx; }
.report-item { display: flex; justify-content: space-between; align-items: center; padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.03); }
.report-info { font-size: 24rpx; color: var(--tx2); }
.report-time { font-size: 20rpx; color: var(--tx3); margin-top: 4rpx; }
.report-actions { display: flex; gap: 8rpx; }
.btn-delete { padding: 8rpx 20rpx; background: rgba(231,76,60,.15); color: #E74C3C; border-radius: 16rpx; font-size: 22rpx; border: none; }
.btn-dismiss { padding: 8rpx 20rpx; background: rgba(255,255,255,.06); color: var(--tx2); border-radius: 16rpx; font-size: 22rpx; border: 1rpx solid var(--bd); }
.user-row { display: flex; justify-content: space-between; padding: 10rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.02); }
.user-name { font-size: 26rpx; color: #fff; }
.user-time { font-size: 22rpx; color: var(--tx3); }
