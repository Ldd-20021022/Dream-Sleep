<view class="container">
  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <block wx:elif="{{group}}">
    <view class="group-header">
      <view class="group-icon">{{group.icon}}</view>
      <view class="group-name">{{group.name}}</view>
      <view class="group-desc">{{group.description}}</view>
      <view class="group-meta">{{group.member_count}} 成员</view>
    </view>

    <view class="join-btn {{isMember ? 'joined' : ''}}" bindtap="toggleJoin">
      {{isMember ? '✓ 已加入' : '+ 加入小组'}}
    </view>

    <!-- Post Composer (members only) -->
    <view wx:if="{{isMember}}" class="card composer">
      <textarea placeholder="在小组里分享..." value="{{postContent}}" bindinput="onPostInput" maxlength="300"/>
      <view wx:if="{{postImage}}" class="img-preview">
        <image src="{{postImage}}" mode="widthFix"/>
        <view class="img-remove" bindtap="removeImage">✕</view>
      </view>
      <view class="composer-row">
        <view class="img-btn" bindtap="chooseImage">📷 图片</view>
        <button class="btn-send" bindtap="createPost" loading="{{posting}}">发布</button>
      </view>
    </view>

    <!-- Posts Feed -->
    <view class="section-title">📝 小组动态 ({{posts.length}})</view>
    <view wx:if="{{posts.length===0}}" class="empty">暂无动态</view>
    <view wx:for="{{posts}}" wx:key="id" class="card post-card" data-id="{{item.id}}" bindtap="openPost">
      <view class="post-author">
        <view class="post-avatar">{{item.author ? item.author[0] : '?'}}</view>
        <view>
          <view class="post-name">{{item.author}}</view>
          <view class="post-time">{{timeAgo(item.created_at)}}</view>
        </view>
      </view>
      <view class="post-content">{{item.content}}</view>
      <image wx:if="{{item.image}}" src="{{item.image}}" mode="widthFix" class="post-img"/>
      <view class="post-meta">❤️ {{item.like_count}} · 💬 {{item.comment_count}}</view>
    </view>

    <!-- Members -->
    <view class="section-title">👥 成员 ({{members.length}})</view>
    <view wx:if="{{members.length===0}}" class="empty">暂无成员</view>
    <view wx:for="{{members}}" wx:key="id" class="member-row">
      <view class="member-avatar">{{item.nickname ? item.nickname[0] : '?'}}</view>
      <view class="member-name">{{item.nickname}}</view>
    </view>
  </block>
  <view wx:else class="empty">小组不存在</view>
</view>
