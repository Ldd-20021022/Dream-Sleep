/* Streak */
.streak-card { padding: 24rpx; text-align: center; }
.streak-label { font-size: 22rpx; color: var(--tx3); margin-bottom: 14rpx; }
.streak-dots { display: flex; gap: 14rpx; justify-content: center; margin-bottom: 10rpx; }
.streak-dot { width: 48rpx; height: 48rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; }
.streak-dot.on { background: rgba(200,146,58,0.12); }
.streak-dot.off { background: rgba(255,255,255,0.03); color: var(--tx3); }
.streak-sub { font-size: 22rpx; color: var(--tx2); font-weight: 500; }

/* Progress */
.prog-card { padding: 22rpx; }
.prog-bar { height: 8rpx; background: rgba(255,255,255,0.05); border-radius: 4rpx; overflow: hidden; margin-bottom: 12rpx; }
.prog-fill { height: 100%; background: var(--primary); border-radius: 4rpx; }
.prog-info { display: flex; justify-content: space-between; font-size: 22rpx; color: var(--tx2); }

/* Time Groups */
.task-group { margin-bottom: 6rpx; }
.group-header { font-size: 22rpx; font-weight: 600; color: var(--tx3); padding: 14rpx 6rpx 6rpx; }

/* Task Cards */
.task-card { padding: 22rpx; margin-bottom: 10rpx; }
.task-card.done { opacity: 0.45; }
.task-row { display: flex; align-items: center; gap: 16rpx; position: relative; }
.task-chk { width: 40rpx; height: 40rpx; min-width: 40rpx; border: 2rpx solid rgba(255,255,255,0.12); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20rpx; color: var(--teal); }
.task-chk.checked { border-color: var(--teal); background: var(--teal-soft); }
.task-body { flex: 1; }
.task-title { font-size: 24rpx; font-weight: 500; margin-bottom: 2rpx; }
.task-desc { font-size: 20rpx; color: var(--tx3); margin-bottom: 6rpx; }
.task-pts { font-size: 20rpx; color: var(--teal); white-space: nowrap; position: relative; }
.task-pts-done { font-size: 20rpx; color: var(--teal); white-space: nowrap; }

.xp-float { position: absolute; right: 0; top: -16rpx; font-size: 24rpx; font-weight: 700; color: var(--warn); animation: floatUp 1.2s ease-out forwards; pointer-events: none; }
@keyframes floatUp {
  0% { opacity: 1; transform: translateY(0) scale(1); }
  50% { opacity: 1; transform: translateY(-36rpx) scale(1.25); }
  100% { opacity: 0; transform: translateY(-72rpx) scale(0.8); }
}

.badge { font-size: 18rpx; padding: 2rpx 10rpx; border-radius: 10rpx; background: var(--primary-soft); color: var(--primary); }
.badge-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10rpx; }
.badge-item { text-align: center; padding: 18rpx 6rpx; border-radius: 16rpx; opacity: 0.35; background: var(--card-bg); }
.badge-item.on { opacity: 1; background: var(--primary-soft); }
.badge-icon { font-size: 40rpx; margin-bottom: 4rpx; }
.badge-name { font-size: 20rpx; }
.badge-desc { font-size: 16rpx; color: var(--tx3); margin-top: 2rpx; }

/* Celebration */
.celebration-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.88); z-index: 9999; display: flex; align-items: center; justify-content: center; animation: fadeIn 0.25s ease; }
.celebration-card { text-align: center; padding: 44rpx; animation: popIn 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
.celebration-confetti { font-size: 44rpx; margin-bottom: 14rpx; }
.celebration-icon { font-size: 100rpx; margin-bottom: 14rpx; }
.celebration-title { font-size: 26rpx; color: var(--tx2); margin-bottom: 6rpx; }
.celebration-name { font-size: 40rpx; font-weight: 700; color: var(--warn); margin-bottom: 6rpx; }
.celebration-desc { font-size: 24rpx; color: var(--tx3); margin-bottom: 28rpx; }
.celebration-btn { font-size: 24rpx; color: var(--primary); padding: 12rpx 40rpx; background: var(--primary-soft); border-radius: 24rpx; display: inline-block; }
@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@keyframes popIn { from { transform: scale(0.5); opacity: 0; } to { transform: scale(1); opacity: 1; } }

.section-title { font-size: 26rpx; font-weight: 600; color: var(--tx2); margin-bottom: 14rpx; }
.empty-state { text-align: center; color: var(--tx3); padding: 28rpx; }
