.container { padding: 24rpx; }
.page-title { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 24rpx; }
.empty { text-align: center; padding: 80rpx; color: var(--tx3); }
.card { background: var(--bg2); border-radius: 20rpx; padding: 24rpx; margin-bottom: 16rpx; border: 1rpx solid var(--bd); }
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }

/* Scale Selection */
.scale-card { display: flex; align-items: center; gap: 16rpx; }
.scale-icon { font-size: 48rpx; }
.scale-info { flex: 1; }
.scale-name { font-size: 28rpx; font-weight: 600; color: #fff; }
.scale-desc { font-size: 24rpx; color: var(--tx3); margin: 4rpx 0; }
.scale-meta { font-size: 22rpx; color: var(--primary); }
.scale-arrow { font-size: 28rpx; color: var(--tx3); }

/* Result */
.result-card { text-align: center; }
.result-score-ring { width: 160rpx; height: 160rpx; border-radius: 50%; background: rgba(108,99,255,.1); border: 4rpx solid var(--primary); display: flex; flex-direction: column; align-items: center; justify-content: center; margin: 16rpx auto; }
.rsr-score { font-size: 56rpx; font-weight: 800; color: #fff; line-height: 1; }
.rsr-max { font-size: 24rpx; color: var(--tx3); }
.result-severity { font-size: 30rpx; font-weight: 700; margin: 12rpx 0; }
.result-severity.normal { color: #2ECC71; }
.result-severity.mild { color: #F39C12; }
.result-severity.moderate { color: #E67E22; }
.result-severity.severe { color: #E74C3C; }
.result-analysis { font-size: 26rpx; color: var(--tx2); text-align: left; line-height: 1.7; margin-top: 16rpx; padding: 16rpx; background: rgba(255,255,255,.03); border-radius: 12rpx; }
.result-disclaimer { font-size: 20rpx; color: var(--tx3); margin-top: 12rpx; }

/* Questions */
.progress-bar { height: 8rpx; background: rgba(255,255,255,.06); border-radius: 4rpx; overflow: hidden; margin-bottom: 8rpx; }
.progress-fill { height: 100%; background: var(--primary); border-radius: 4rpx; transition: width 0.3s; }
.progress-text { font-size: 22rpx; color: var(--tx3); margin-bottom: 20rpx; text-align: center; }
.q-item { display: flex; gap: 12rpx; margin-bottom: 24rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid rgba(255,255,255,.04); }
.q-num { width: 36rpx; height: 36rpx; border-radius: 50%; background: rgba(108,99,255,.15); display: flex; align-items: center; justify-content: center; font-size: 20rpx; color: var(--primary); font-weight: 600; flex-shrink: 0; }
.q-body { flex: 1; }
.q-text { font-size: 26rpx; color: #fff; margin-bottom: 10rpx; line-height: 1.5; }
.q-opts { display: flex; flex-wrap: wrap; gap: 8rpx; }
.q-opt { padding: 10rpx 20rpx; background: rgba(255,255,255,.04); border: 1rpx solid var(--bd); border-radius: 20rpx; font-size: 24rpx; color: var(--tx2); }
.q-opt.on { background: rgba(108,99,255,.15); border-color: var(--primary); color: var(--primary); font-weight: 600; }
.q-input { padding: 12rpx 18rpx; background: rgba(255,255,255,.04); border: 1rpx solid var(--bd); border-radius: 12rpx; font-size: 24rpx; color: #fff; }
.btn-full { width: 100%; margin-top: 16rpx; }
