<view class="container"><view class="page-title">🔗 邀请好友</view>
  <view class="hero-card">
    <view style="font-size:80rpx;text-align:center">🎁</view>
    <view style="font-size:32rpx;font-weight:700;color:#fff;text-align:center;margin:16rpx 0">邀请好友一起改善睡眠</view>
    <view style="font-size:24rpx;color:var(--tx2);text-align:center">每邀请1位好友注册，双方各得奖励</view>
  </view>
  <view class="card" style="text-align:center">
    <view style="font-size:24rpx;color:var(--tx3);margin-bottom:8rpx">你的邀请码</view>
    <view style="font-size:48rpx;font-weight:800;color:var(--primary);letter-spacing:8rpx;margin-bottom:16rpx">{{code || '加载中...'}}</view>
    <view style="display:flex;gap:12rpx;justify-content:center">
      <button class="btn btn-primary btn-sm" bindtap="copyCode">📋 复制邀请码</button>
      <button class="btn btn-secondary btn-sm" bindtap="shareToChat">📤 分享给好友</button>
    </view>
  </view>
  <view class="card">
    <view class="section-title">📊 邀请统计</view>
    <view style="display:flex;gap:24rpx;text-align:center">
      <view style="flex:1"><view style="font-size:40rpx;font-weight:700;color:#fff">{{inviteCount}}</view><view style="font-size:22rpx;color:var(--tx3)">已邀请</view></view>
      <view style="flex:1"><view style="font-size:40rpx;font-weight:700;color:#F39C12">¥{{rewardYuan}}</view><view style="font-size:22rpx;color:var(--tx3)">奖励金</view></view>
    </view>
  </view>
  <view class="card">
    <view class="section-title">✍️ 我有邀请码</view>
    <view style="display:flex;gap:12rpx">
      <input placeholder="输入邀请码" value="{{applyCode}}" bindinput="onInput" maxlength="10" style="flex:1;padding:16rpx;border-radius:12rpx;border:1rpx solid var(--bd);font-size:26rpx"/>
      <button class="btn btn-primary btn-sm" bindtap="applyReferral">使用</button>
    </view>
  </view>
  <view class="info-card">
    <text style="font-size:24rpx;color:var(--tx2);line-height:1.7">💡 邀请奖励规则：\n• 每成功邀请1人，邀请人获得10元奖励金 + 50XP\n• 被邀请人获得50XP新手奖励\n• 奖励金可用于商城购物或兑换会员</text>
  </view>
</view>
