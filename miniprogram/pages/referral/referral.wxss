.container { padding: 24rpx; }
.page-title { font-size: 40rpx; font-weight: 800; color: #fff; margin-bottom: 24rpx; }
.hero-card { background: linear-gradient(135deg, #1a1a4e, #0f0f3e); border-radius: 20rpx; padding: 32rpx; margin-bottom: 20rpx; border: 1rpx solid rgba(108,99,255,.2); }
.card { background: var(--bg2); border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx; border: 1rpx solid var(--bd); }
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }
.info-card { background: rgba(108,99,255,.06); border-radius: 16rpx; padding: 20rpx 24rpx; margin-bottom: 20rpx; border: 1rpx solid rgba(108,99,255,.1); }
.btn { border-radius: 30rpx; font-size: 26rpx; padding: 16rpx 32rpx; text-align: center; border: none; }
.btn-primary { background: var(--primary); color: #fff; }
.btn-secondary { background: rgba(255,255,255,.06); color: var(--tx2); border: 1rpx solid var(--bd); }
.btn-sm { padding: 10rpx 20rpx; font-size: 24rpx; }
