.container { padding: 24rpx; }
.page-title { font-size: 38rpx; font-weight: 600; margin-bottom: 20rpx; }

.tab-bar { display: flex; gap: 4rpx; background: var(--card-bg); border-radius: 18rpx; padding: 4rpx; margin-bottom: 20rpx; }
.tab-item { flex: 1; text-align: center; padding: 12rpx 0; border-radius: 15rpx; font-size: 22rpx; color: var(--tx3); }
.tab-item.on { background: var(--primary-soft); color: var(--primary); font-weight: 600; }

.product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; }
.product-card { background: var(--card-bg); border-radius: 18rpx; padding: 20rpx; text-align: center; }
.pc-image { font-size: 56rpx; margin-bottom: 10rpx; }
.pc-name { font-size: 24rpx; font-weight: 600; margin-bottom: 10rpx; line-height: 1.3; }
.pc-price-row { display: flex; justify-content: center; align-items: baseline; gap: 8rpx; margin-bottom: 6rpx; }
.pc-price { font-size: 28rpx; font-weight: 700; color: var(--danger); }
.pc-sales { font-size: 20rpx; color: var(--tx3); }
.pc-rating { font-size: 20rpx; color: var(--tx3); }

.cart-item { display: flex; align-items: center; gap: 14rpx; background: var(--card-bg); border-radius: 18rpx; padding: 18rpx 20rpx; margin-bottom: 10rpx; }
.ci-icon { font-size: 40rpx; flex-shrink: 0; }
.ci-info { flex: 1; }
.ci-name { font-size: 26rpx; font-weight: 600; }
.ci-meta { font-size: 22rpx; color: var(--tx3); margin-top: 4rpx; }
.ci-subtotal { font-size: 24rpx; font-weight: 600; color: var(--danger); }
.ci-del { font-size: 24rpx; padding: 8rpx; }
.cart-footer { display: flex; justify-content: space-between; align-items: center; background: var(--card-bg); border-radius: 18rpx; padding: 20rpx; margin-top: 16rpx; }
.cf-total { font-size: 26rpx; color: var(--tx2); }
.cf-price { font-size: 36rpx; font-weight: 700; color: var(--danger); }

.coupon-card { display: flex; gap: 16rpx; background: var(--card-bg); border-radius: 18rpx; padding: 20rpx; margin-bottom: 12rpx; align-items: center; }
.cp-left { text-align: center; min-width: 100rpx; }
.cp-discount { font-size: 40rpx; font-weight: 800; color: var(--warn); }
.cp-label { font-size: 20rpx; color: var(--tx3); }
.cp-mid { flex: 1; }
.cp-code { font-size: 28rpx; font-weight: 600; }
.cp-used { font-size: 22rpx; color: var(--tx3); margin-top: 4rpx; }

.order-card { background: var(--card-bg); border-radius: 18rpx; padding: 18rpx 20rpx; margin-bottom: 10rpx; }
.oc-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10rpx; }
.oc-no { font-size: 22rpx; color: var(--tx3); }
.oc-status { font-size: 22rpx; font-weight: 600; padding: 4rpx 12rpx; border-radius: 10rpx; }
.oc-status.pending { color: var(--warn); background: rgba(212,164,74,.1); }
.oc-status.paid { color: var(--primary); background: var(--primary-soft); }
.oc-status.completed { color: var(--success); background: var(--teal-soft); }
.oc-bottom { display: flex; justify-content: space-between; }
.oc-amount { font-size: 28rpx; font-weight: 700; }
.oc-time { font-size: 22rpx; color: var(--tx3); }

.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,.85); z-index: 999; display: flex; align-items: center; justify-content: center; padding: 40rpx; animation: fadeIn .2s; }
@keyframes fadeIn { from{opacity:0} to{opacity:1} }
.modal-card { width: 100%; max-width: 560rpx; background: var(--bg); border-radius: 28rpx; padding: 36rpx 28rpx; position: relative; animation: slideUp .3s; }
@keyframes slideUp { from{transform:translateY(40rpx)} to{transform:translateY(0)} }
.modal-close { position: absolute; top: 20rpx; right: 20rpx; width: 44rpx; height: 44rpx; border-radius: 50%; background: rgba(255,255,255,.06); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: var(--tx3); }
.md-image { font-size: 80rpx; text-align: center; margin-bottom: 16rpx; }
.md-name { font-size: 32rpx; font-weight: 700; text-align: center; }
.md-desc { font-size: 24rpx; color: var(--tx2); text-align: center; margin: 10rpx 0; line-height: 1.5; }
.md-price { font-size: 44rpx; font-weight: 800; color: var(--danger); text-align: center; margin: 14rpx 0; }
.md-meta { text-align: center; font-size: 22rpx; color: var(--tx3); }

.qty-row { display: flex; align-items: center; justify-content: center; gap: 24rpx; margin: 16rpx 0; }
.qty-btn { width: 52rpx; height: 52rpx; border-radius: 50%; background: var(--card-bg); display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 600; }
.qty-val { font-size: 40rpx; font-weight: 700; min-width: 56rpx; text-align: center; }

.empty { text-align: center; padding: 80rpx 40rpx; color: var(--tx3); }
.empty-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.empty-text { font-size: 26rpx; margin-bottom: 6rpx; }
.empty-hint { font-size: 22rpx; color: var(--tx3); }
