.product-item{display:flex;justify-content:space-between;padding:20rpx 0;border-bottom:1rpx solid var(--bd)}.product-name{font-weight:600;font-size:28rpx}.product-desc{font-size:24rpx;color:var(--tx3)}.product-meta{font-size:22rpx;color:var(--tx3);margin-top:4rpx}.product-price{font-size:32rpx;font-weight:700;color:var(--ac)}.cart-item{display:flex;justify-content:space-between;align-items:center;padding:12rpx 0}.modal{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:999}.modal-box{background:var(--card);border-radius:16rpx;padding:32rpx;width:80vw;max-width:500rpx}