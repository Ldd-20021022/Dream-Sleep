<view class="container">
  <view class="page-title">🛍️ 助眠商城</view>

  <!-- Tabs -->
  <view class="tab-bar">
    <view class="tab-item {{tab==='products'?'on':''}}" data-tab="products" bindtap="switchTab">商品</view>
    <view class="tab-item {{tab==='cart'?'on':''}}" data-tab="cart" bindtap="switchTab">购物车 {{cartCount>0?'·'+cartCount:''}}</view>
    <view class="tab-item {{tab==='coupons'?'on':''}}" data-tab="coupons" bindtap="switchTab">优惠券</view>
    <view class="tab-item {{tab==='orders'?'on':''}}" data-tab="orders" bindtap="switchTab">订单</view>
  </view>

  <!-- ===== Products ===== -->
  <view wx:if="{{tab==='products'}}">
    <view wx:if="{{products.length===0}}" class="empty">加载商品中...</view>
    <view class="product-grid">
      <view wx:for="{{products}}" wx:key="id" class="product-card" data-id="{{item.id}}" bindtap="viewProduct">
        <view class="pc-image">{{item.category==='眼罩'?'😴':item.category==='香薰'?'🕯️':item.category==='寝具'?'🛏️':item.category==='音箱'?'🔊':item.category==='枕头'?'💤':item.category==='补充剂'?'💊':item.category==='耳塞'?'🎧':'📦'}}</view>
        <view class="pc-name">{{item.name}}</view>
        <view class="pc-price-row">
          <view class="pc-price">¥{{item.price_yuan}}</view>
          <view class="pc-sales">已售 {{item.sales}}</view>
        </view>
        <view class="pc-rating">⭐ {{item.rating}} · {{item.stock}}件</view>
      </view>
    </view>
  </view>

  <!-- ===== Cart ===== -->
  <view wx:if="{{tab==='cart'}}">
    <view wx:if="{{cart.length===0}}" class="empty">
      <view class="empty-icon">🛒</view>
      <view class="empty-text">购物车是空的</view>
      <view class="empty-hint">去挑选一些助眠好物吧</view>
    </view>
    <view wx:for="{{cart}}" wx:key="id" class="cart-item">
      <view class="ci-icon">📦</view>
      <view class="ci-info">
        <view class="ci-name">{{item.name}}</view>
        <view class="ci-meta">x{{item.quantity}} · ¥{{item.price_yuan}}/件</view>
      </view>
      <view class="ci-subtotal">¥{{item.subtotal_yuan || item.price_yuan * item.quantity}}</view>
      <view class="ci-del" data-id="{{item.id}}" bindtap="removeFromCart">🗑</view>
    </view>
    <view wx:if="{{cart.length>0}}" class="cart-footer">
      <view class="cf-total">合计 <text class="cf-price">¥{{cartTotal}}</text></view>
      <button class="btn btn-primary" bindtap="createOrder">📦 提交订单</button>
    </view>
  </view>

  <!-- ===== Coupons ===== -->
  <view wx:if="{{tab==='coupons'}}">
    <view wx:if="{{coupons.length===0}}" class="empty">暂无可用优惠券</view>
    <view wx:for="{{coupons}}" wx:key="id" class="coupon-card">
      <view class="cp-left">
        <view class="cp-discount">{{item.discount_percent || item.discount}}%</view>
        <view class="cp-label">折扣</view>
      </view>
      <view class="cp-mid">
        <view class="cp-code">{{item.code}}</view>
        <view class="cp-used">已领 {{item.used_count || item.used}}/{{item.max_count || item.max}}</view>
      </view>
      <view class="cp-right">
        <button class="btn btn-primary btn-sm" data-code="{{item.code}}" bindtap="claimCoupon">领取</button>
      </view>
    </view>
  </view>

  <!-- ===== Orders ===== -->
  <view wx:if="{{tab==='orders'}}">
    <view wx:if="{{orders.length===0}}" class="empty">
      <view class="empty-icon">📋</view>
      <view class="empty-text">暂无订单</view>
    </view>
    <view wx:for="{{orders}}" wx:key="id" class="order-card">
      <view class="oc-top">
        <view class="oc-no">{{item.order_no}}</view>
        <view class="oc-status {{item.status}}">{{item.status==='pending'?'待付款':item.status==='paid'?'已付款':item.status==='shipped'?'已发货':item.status==='completed'?'已完成':'已取消'}}</view>
      </view>
      <view class="oc-bottom">
        <view class="oc-amount">¥{{item.total_yuan}}</view>
        <view class="oc-time">{{item.created_at ? item.created_at.slice(0,10) : ''}}</view>
      </view>
    </view>
  </view>

  <!-- ===== Product Detail Modal ===== -->
  <view wx:if="{{viewing}}" class="modal-overlay" bindtap="closeView">
    <view class="modal-card" catchtap="noop">
      <view class="modal-close" bindtap="closeView">✕</view>
      <view class="md-image">{{viewing.category==='眼罩'?'😴':viewing.category==='香薰'?'🕯️':viewing.category==='寝具'?'🛏️':viewing.category==='音箱'?'🔊':viewing.category==='枕头'?'💤':viewing.category==='补充剂'?'💊':viewing.category==='耳塞'?'🎧':'📦'}}</view>
      <view class="md-name">{{viewing.name}}</view>
      <view class="md-desc">{{viewing.desc}}</view>
      <view class="md-price">¥{{viewing.price_yuan}}</view>
      <view class="md-meta">⭐ {{viewing.rating}} · 库存 {{viewing.stock}} · 已售 {{viewing.sales}}</view>
      <button class="btn btn-primary" style="width:100%;margin-top:16rpx" bindtap="openQty">加入购物车</button>
    </view>
  </view>

  <!-- ===== Quantity Selector Modal ===== -->
  <view wx:if="{{showQty}}" class="modal-overlay" bindtap="closeView">
    <view class="modal-card" catchtap="noop">
      <view class="modal-close" bindtap="closeView">✕</view>
      <view style="text-align:center;font-size:30rpx;font-weight:600;margin-bottom:24rpx">{{qtyProduct.name}}</view>
      <view class="qty-row">
        <view class="qty-btn" bindtap="subQty">−</view>
        <view class="qty-val">{{qty}}</view>
        <view class="qty-btn" bindtap="addQty">+</view>
      </view>
      <view style="text-align:center;color:var(--tx3);margin:12rpx 0">小计：¥{{qtySubtotal}}</view>
      <button class="btn btn-primary" style="width:100%" bindtap="confirmAddToCart">确认添加</button>
    </view>
  </view>
</view>
