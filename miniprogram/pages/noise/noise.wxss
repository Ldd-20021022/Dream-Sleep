.scene-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.scene-btn { width: calc(50% - 8rpx); padding: 24rpx; background: var(--hover); border-radius: 16rpx; text-align: center; border: 2rpx solid transparent; }
.scene-btn.on { border-color: var(--ac); background: rgba(108,99,255,0.1); }
.scene-icon { font-size: 48rpx; }
.scene-name { font-size: 28rpx; font-weight: 600; margin: 8rpx 0 4rpx; }
.scene-desc { font-size: 22rpx; color: var(--tx3); }
.ctrl-row { display: flex; align-items: center; gap: 16rpx; }
.ctrl-label { width: 120rpx; font-size: 28rpx; color: var(--tx2); }
.ctrl-val { width: 80rpx; text-align: right; font-size: 26rpx; color: var(--tx3); }
.tip-card { background: rgba(108,99,255,0.06); border-color: var(--ac); font-size: 26rpx; color: var(--tx2); }
.story-item { display: flex; align-items: center; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid var(--bd); }
.story-item:last-child { border-bottom: none; }
.story-info { flex: 1; margin-right: 16rpx; }
.story-title { font-size: 28rpx; font-weight: 500; }
.story-meta { font-size: 22rpx; color: var(--tx3); margin-top: 4rpx; }
