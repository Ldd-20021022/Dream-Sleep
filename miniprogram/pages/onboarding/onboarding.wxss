.container { padding: 48rpx 36rpx 200rpx; min-height: 100vh; }

/* Progress */
.ob-progress { display: flex; align-items: center; justify-content: center; margin-bottom: 56rpx; gap: 0; }
.ob-dot { width: 56rpx; height: 56rpx; border-radius: 50%; background: rgba(255,255,255,0.04); border: 2rpx solid rgba(255,255,255,0.08); display: flex; align-items: center; justify-content: center; transition: all 0.4s; flex-shrink: 0; }
.ob-dot-inner { font-size: 22rpx; color: var(--tx3); font-weight: 500; }
.ob-dot.current { border-color: var(--primary); background: rgba(139,156,247,0.1); box-shadow: 0 0 16rpx rgba(139,156,247,0.2); }
.ob-dot.current .ob-dot-inner { color: var(--primary); }
.ob-dot.done { border-color: var(--teal); background: rgba(94,234,212,0.08); }
.ob-dot.done .ob-dot-inner { color: var(--teal); }
.ob-line { width: 48rpx; height: 2rpx; background: rgba(255,255,255,0.06); flex-shrink: 0; transition: background 0.4s; }
.ob-line.done { background: rgba(94,234,212,0.3); }

/* Header */
.ob-header { text-align: center; margin-bottom: 48rpx; }
.ob-icon { font-size: 80rpx; margin-bottom: 16rpx; }
.ob-title { font-size: 40rpx; font-weight: 700; color: #fff; margin-bottom: 8rpx; }
.ob-sub { font-size: 26rpx; color: var(--tx3); margin-bottom: 12rpx; }
.ob-required { font-size: 20rpx; color: var(--warn); }

/* Body */
.ob-body { min-height: 400rpx; }

/* Labels */
.form-label { font-size: 26rpx; color: var(--tx2); margin-bottom: 14rpx; font-weight: 500; }
.req { color: var(--err); font-size: 24rpx; }

/* Input */
.ob-input { width: 100%; height: 84rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 0 24rpx; font-size: 28rpx; color: #fff; box-sizing: border-box; }
.ob-input:focus { border-color: var(--primary); }
.ob-picker { line-height: 84rpx; color: var(--tx); }
.ob-row { display: flex; }
.ob-textarea { width: 100%; height: 180rpx; background: rgba(255,255,255,0.04); border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; padding: 20rpx 24rpx; font-size: 26rpx; color: #fff; box-sizing: border-box; }
.ob-textarea:focus { border-color: var(--primary); }

/* Chips */
.ob-chip-row { display: flex; flex-wrap: wrap; gap: 14rpx; }
.ob-chip { padding: 18rpx 28rpx; border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; font-size: 26rpx; color: var(--tx2); transition: all 0.2s; }
.ob-chip.on { border-color: var(--primary); background: rgba(139,156,247,0.1); color: var(--primary); }

/* Fold */
.ob-fold { border: 1rpx solid rgba(255,255,255,0.08); border-radius: 16rpx; overflow: hidden; }
.ob-fold.open { border-color: rgba(139,156,247,0.3); }
.ob-fold-hd { padding: 22rpx 28rpx; display: flex; justify-content: space-between; align-items: center; }
.ob-fold-label { flex: 1; font-size: 26rpx; color: var(--tx3); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.ob-fold.open .ob-fold-label { color: var(--tx2); }
.ob-fold-arrow { font-size: 20rpx; color: var(--tx3); margin-left: 16rpx; }
.ob-fold-bd { padding: 8rpx 20rpx 20rpx; display: flex; flex-wrap: wrap; gap: 12rpx; }
.ob-fold-chip { padding: 16rpx 24rpx; border: 1rpx solid rgba(255,255,255,0.08); border-radius: 14rpx; font-size: 24rpx; color: var(--tx2); transition: all 0.2s; }
.ob-fold-chip.on { border-color: var(--primary); background: rgba(139,156,247,0.1); color: var(--primary); }

/* Error */
.ob-err { color: var(--err); font-size: 24rpx; padding: 16rpx 24rpx; background: rgba(240,96,112,0.08); border-radius: 14rpx; margin-bottom: 24rpx; margin-top: 24rpx; }

/* Bottom */
.ob-bottom { position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 36rpx 48rpx; background: linear-gradient(0deg, var(--bg) 60%, transparent); display: flex; justify-content: space-between; align-items: center; }
.ob-bottom-left { flex: 1; }
.ob-btn-back { font-size: 28rpx; color: var(--tx3); padding: 16rpx 0; }
.ob-btn-next { padding: 20rpx 48rpx; background: linear-gradient(135deg, var(--primary), #7a8ae0); color: #fff; font-size: 28rpx; font-weight: 600; border-radius: 40rpx; }
.ob-btn-next:active { opacity: 0.8; }

.form-group { margin-bottom: 28rpx; }
