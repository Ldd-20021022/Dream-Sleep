.tabs { display: flex; gap: 8rpx; margin-bottom: 24rpx; }
.tab { padding: 12rpx 32rpx; border-radius: 32rpx; font-size: 26rpx; color: var(--tx2); background: var(--card); }
.tab.on { background: var(--ac); color: #fff; }
.row-between { display: flex; align-items: center; justify-content: space-between; }
.g-icon { font-size: 40rpx; margin-right: 16rpx; }
.g-name { font-weight: 600; font-size: 28rpx; }
.g-desc { font-size: 24rpx; color: var(--tx3); margin-top: 8rpx; }
.period-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.lb-item { display: flex; align-items: center; gap: 20rpx; }
.lb-rank { font-weight: 700; font-size: 30rpx; width: 40rpx; }
.lb-name { flex: 1; font-size: 28rpx; }
.lb-score { color: var(--teal); font-weight: 600; }
.post-author { font-weight: 600; font-size: 26rpx; }
.post-time { font-size: 22rpx; color: var(--tx3); }
.post-content { margin-top: 12rpx; font-size: 28rpx; line-height: 1.6; }
.cb { display: flex; align-items: center; font-size: 24rpx; color: var(--tx2); }
