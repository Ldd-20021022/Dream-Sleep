.container { padding: 24rpx; }
.top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.page-title { font-size: 40rpx; font-weight: 800; color: #fff; }
.mark-all-btn { font-size: 24rpx; color: var(--primary); }
.notif-item { display: flex; gap: 14rpx; padding: 20rpx 16rpx; border-radius: 14rpx; margin-bottom: 8rpx; align-items: flex-start; position: relative; }
.notif-item.unread { background: rgba(108,99,255,.06); border: 1rpx solid rgba(108,99,255,.1); }
.notif-item.read { opacity: 0.6; }
.notif-icon { font-size: 36rpx; flex-shrink: 0; }
.notif-body { flex: 1; }
.notif-title { font-size: 26rpx; font-weight: 600; color: #fff; }
.notif-text { font-size: 24rpx; color: var(--tx2); margin: 4rpx 0; }
.notif-time { font-size: 20rpx; color: var(--tx3); }
.unread-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: #E74C3C; position: absolute; top: 22rpx; right: 16rpx; }
.empty { text-align: center; padding: 80rpx 0; color: var(--tx3); }
.empty-icon { font-size: 64rpx; margin-bottom: 12rpx; }
