.container { padding: 24rpx 24rpx 160rpx; }
.empty { text-align: center; padding: 80rpx 0; color: var(--tx3); }
.empty-text { text-align: center; color: var(--tx3); padding: 40rpx; font-size: 26rpx; }

/* Author bar */
.author-bar { display: flex; align-items: center; gap: 14rpx; margin-bottom: 20rpx; }
.author-avatar { width: 56rpx; height: 56rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; color: #fff; }
.author-info { flex: 1; }
.author-name { font-size: 28rpx; font-weight: 600; color: #fff; }
.post-time { font-size: 22rpx; color: var(--tx3); }
.follow-btn { padding: 8rpx 20rpx; border-radius: 20rpx; background: var(--primary); color: #fff; font-size: 22rpx; }
.follow-btn.following { background: rgba(255,255,255,.06); color: var(--tx2); border: 1rpx solid var(--bd); }

/* Content */
.post-content { font-size: 30rpx; line-height: 1.7; color: var(--tx1); margin-bottom: 16rpx; }
.post-image { width: 100%; border-radius: 12rpx; margin-bottom: 16rpx; }
.post-meta-row { display: flex; gap: 8rpx; margin-bottom: 16rpx; }
.score-badge { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 12rpx; }
.score-badge.good { background: rgba(46,204,113,.15); color: #2ECC71; }
.score-badge.ok { background: rgba(243,156,18,.15); color: #F39C12; }
.topic-badge { font-size: 22rpx; padding: 4rpx 12rpx; border-radius: 12rpx; background: rgba(108,99,255,.1); color: var(--primary); }

/* Actions bar */
.post-actions-bar { display: flex; gap: 16rpx; padding: 20rpx 0; border-top: 1rpx solid rgba(255,255,255,.06); border-bottom: 1rpx solid rgba(255,255,255,.06); margin-bottom: 24rpx; }
.action-btn { font-size: 26rpx; color: var(--tx2); padding: 8rpx 16rpx; border-radius: 14rpx; }
.action-btn.liked { color: #E74C3C; }
.action-btn.bookmarked { color: #F39C12; }

/* Comments */
.comments-section {}
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 16rpx; }
.comment-item { display: flex; gap: 12rpx; margin-bottom: 20rpx; }
.comment-avatar { width: 40rpx; height: 40rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18rpx; font-weight: 700; color: #fff; flex-shrink: 0; }
.comment-body { flex: 1; }
.comment-author { font-size: 24rpx; font-weight: 600; color: #fff; margin-bottom: 4rpx; }
.comment-time { font-size: 20rpx; color: var(--tx3); font-weight: 400; }
.comment-content { font-size: 26rpx; color: var(--tx2); line-height: 1.5; }
.comment-actions-inline { display: flex; gap: 14rpx; margin-top: 6rpx; }
.ca-like { font-size: 20rpx; color: var(--tx3); }
.ca-reply { font-size: 20rpx; color: var(--primary); }

/* Nested replies */
.nested-replies { margin-top: 10rpx; margin-left: 8rpx; padding-left: 16rpx; border-left: 2rpx solid rgba(108,99,255,.2); }
.reply-item { display: flex; gap: 8rpx; margin-top: 10rpx; }
.reply-avatar { width: 32rpx; height: 32rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 16rpx; font-weight: 700; color: #fff; flex-shrink: 0; }
.reply-body { flex: 1; }
.reply-author { font-size: 22rpx; font-weight: 600; color: #fff; }
.reply-content { font-size: 24rpx; color: var(--tx2); margin-top: 2rpx; line-height: 1.4; }

/* Fixed comment bar */
.comment-fixed-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); background: var(--bg); border-top: 1rpx solid var(--bd); z-index: 100; }
.reply-hint { font-size: 22rpx; color: var(--primary); padding: 6rpx 16rpx; background: rgba(108,99,255,.08); border-radius: 10rpx; margin-bottom: 8rpx; }
.reply-cancel { color: var(--tx3); font-size: 20rpx; margin-left: 8rpx; }
.cfb-row { display: flex; gap: 10rpx; }
.cfb-input { flex: 1; padding: 12rpx 18rpx; background: var(--bg2); border-radius: 24rpx; font-size: 26rpx; color: #fff; border: 1rpx solid var(--bd); }
.cfb-send { padding: 12rpx 24rpx; background: var(--primary); color: #fff; border-radius: 24rpx; font-size: 24rpx; border: none; }
