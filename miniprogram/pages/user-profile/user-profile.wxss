.container { padding: 32rpx; }
.loading { text-align: center; padding: 80rpx; color: var(--tx3); }
.profile-header { text-align: center; margin-bottom: 28rpx; }
.profile-avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #fff; font-weight: 700; margin: 0 auto 16rpx; }
.profile-name { font-size: 36rpx; font-weight: 700; color: #fff; }
.stats-row { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.stat { flex: 1; text-align: center; padding: 20rpx; background: var(--bg2); border-radius: 14rpx; }
.stat-num { font-size: 36rpx; font-weight: 700; color: #fff; }
.stat-label { font-size: 22rpx; color: var(--tx3); margin-top: 4rpx; }
.profile-actions { display: flex; gap: 12rpx; justify-content: center; margin-bottom: 32rpx; }
.profile-btn { padding: 14rpx 28rpx; border-radius: 30rpx; font-size: 24rpx; font-weight: 600; }
.profile-btn.follow { background: var(--primary); color: #fff; }
.profile-btn.follow.following { background: rgba(255,255,255,.06); color: var(--tx2); border: 1rpx solid var(--bd); }
.profile-btn.dm { background: rgba(255,255,255,.06); color: var(--tx2); border: 1rpx solid var(--bd); }
.profile-btn.more { background: rgba(255,255,255,.06); color: var(--tx3); border: 1rpx solid var(--bd); padding: 14rpx 16rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.post-item { padding: 16rpx; background: var(--bg2); border-radius: 12rpx; margin-bottom: 8rpx; border: 1rpx solid var(--bd); }
.post-content { font-size: 26rpx; color: var(--tx1); line-height: 1.5; }
.post-meta { font-size: 22rpx; color: var(--tx3); margin-top: 8rpx; }
.badge-section { margin-bottom: 20rpx; }
.badge-row { display: flex; flex-wrap: wrap; gap: 8rpx; }
.badge-chip { display: flex; align-items: center; gap: 4rpx; padding: 8rpx 14rpx; background: rgba(108,99,255,.1); border: 1rpx solid rgba(108,99,255,.2); border-radius: 20rpx; font-size: 22rpx; color: var(--primary); }
.empty { text-align: center; padding: 60rpx; color: var(--tx3); }
