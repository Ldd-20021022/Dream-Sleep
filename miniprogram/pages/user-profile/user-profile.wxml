<view class="container">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <block wx:elif="{{profile}}">
    <!-- Profile Header -->
    <view class="profile-header">
      <view class="profile-avatar">{{profile.user.nickname ? profile.user.nickname[0] : '?'}}</view>
      <view class="profile-name">{{profile.user.nickname}}</view>
    </view>

    <!-- Stats -->
    <view class="stats-row">
      <view class="stat"><view class="stat-num">{{profile.stats.post_count}}</view><view class="stat-label">帖子</view></view>
      <view class="stat"><view class="stat-num">{{profile.stats.follower_count}}</view><view class="stat-label">粉丝</view></view>
      <view class="stat"><view class="stat-num">{{profile.stats.following_count}}</view><view class="stat-label">关注</view></view>
      <view class="stat"><view class="stat-num">{{profile.stats.total_likes}}</view><view class="stat-label">获赞</view></view>
    </view>

    <!-- Action Buttons -->
    <view class="profile-actions">
      <view class="profile-btn follow {{following ? 'following' : ''}}" bindtap="toggleFollow">
        {{following ? '✓ 已关注' : '+ 关注'}}
      </view>
      <view class="profile-btn dm" bindtap="sendMessage">💬 私信</view>
      <view class="profile-btn more" bindtap="blockUser">···</view>
    </view>

    <!-- Badges -->
    <view wx:if="{{badges.length > 0}}" class="badge-section">
      <view class="section-title">🏅 成就徽章</view>
      <view class="badge-row">
        <view wx:for="{{badges}}" wx:key="badge_id" class="badge-chip">
          <text>{{item.icon}}</text>
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- Recent Posts -->
    <view class="section-title">近期帖子</view>
    <view wx:if="{{profile.recent_posts.length===0}}" class="empty">暂无帖子</view>
    <view wx:for="{{profile.recent_posts}}" wx:key="id" class="post-item" data-id="{{item.id}}" bindtap="openPost">
      <view class="post-content">{{item.content}}</view>
      <view class="post-meta">
        <text wx:if="{{item.sleep_score}}">⭐{{item.sleep_score}} · </text>
        ❤️{{item.like_count}} · 💬{{item.comment_count}}
      </view>
    </view>
  </block>
  <view wx:else class="empty">用户不存在</view>
</view>
