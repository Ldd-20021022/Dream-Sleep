.container { padding: 24rpx; }
.search-bar { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.search-input { flex: 1; padding: 16rpx 20rpx; background: var(--bg2); border: 1rpx solid var(--bd); border-radius: 30rpx; font-size: 28rpx; color: #fff; }
.search-btn { padding: 16rpx 28rpx; background: var(--primary); color: #fff; border-radius: 30rpx; font-size: 26rpx; font-weight: 600; }
.loading { text-align: center; padding: 60rpx; color: var(--tx3); }
.section { margin-bottom: 24rpx; }
.section-title { font-size: 28rpx; font-weight: 700; color: #fff; margin-bottom: 12rpx; }
.result-item { padding: 16rpx; background: var(--bg2); border-radius: 12rpx; margin-bottom: 8rpx; border: 1rpx solid var(--bd); }
.ri-author { font-size: 22rpx; color: var(--tx3); margin-bottom: 6rpx; }
.ri-content { font-size: 26rpx; color: var(--tx1); line-height: 1.5; }
.user-row { display: flex; align-items: center; gap: 12rpx; }
.user-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; font-size: 22rpx; color: #fff; font-weight: 700; }
.user-name { flex: 1; font-size: 26rpx; color: #fff; }
.topic-row { display: flex; gap: 12rpx; align-items: center; }
.topic-icon { font-size: 36rpx; }
.topic-title { font-size: 26rpx; color: #fff; font-weight: 600; }
.topic-desc { font-size: 22rpx; color: var(--tx3); }
.empty { text-align: center; padding: 80rpx 0; color: var(--tx3); }
.empty-icon { font-size: 64rpx; margin-bottom: 12rpx; }
.empty-text { text-align: center; color: var(--tx3); padding: 40rpx; }
.history-header { display: flex; justify-content: space-between; align-items: center; }
.clear-btn { font-size: 22rpx; color: #E74C3C; }
.history-chip { display: inline-block; padding: 10rpx 20rpx; background: var(--bg2); border-radius: 20rpx; margin: 0 8rpx 8rpx 0; font-size: 24rpx; color: var(--tx2); border: 1rpx solid var(--bd); }
