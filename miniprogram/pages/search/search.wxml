<view class="container">
  <view class="search-bar">
    <input class="search-input" placeholder="搜索帖子、用户、话题..." value="{{query}}" bindinput="onInput" bindconfirm="doSearch" focus/>
    <view class="search-btn" bindtap="doSearch">搜索</view>
  </view>

  <!-- Results -->
  <view wx:if="{{searched}}">
    <view wx:if="{{searching}}" class="loading">搜索中...</view>

    <block wx:elif="{{results}}">
      <!-- Posts -->
      <view wx:if="{{results.posts.length > 0}}" class="section">
        <view class="section-title">📝 帖子</view>
        <view wx:for="{{results.posts}}" wx:key="id" class="result-item" data-id="{{item.id}}" bindtap="openPost">
          <view class="ri-author">{{item.author}} · {{item.like_count}}❤️</view>
          <view class="ri-content">{{item.content}}</view>
        </view>
      </view>

      <!-- Users -->
      <view wx:if="{{results.users.length > 0}}" class="section">
        <view class="section-title">👤 用户</view>
        <view wx:for="{{results.users}}" wx:key="id" class="result-item user-row" data-id="{{item.id}}" bindtap="openUser">
          <view class="user-avatar">{{item.nickname ? item.nickname[0] : '?'}}</view>
          <view class="user-name">{{item.nickname}}</view>
          <text>→</text>
        </view>
      </view>

      <!-- Topics -->
      <view wx:if="{{results.topics.length > 0}}" class="section">
        <view class="section-title">💬 话题</view>
        <view wx:for="{{results.topics}}" wx:key="id" class="result-item topic-row">
          <view class="topic-icon">{{item.icon}}</view>
          <view>
            <view class="topic-title">{{item.title}}</view>
            <view class="topic-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>

      <view wx:if="{{results.posts.length===0 && results.users.length===0 && results.topics.length===0}}" class="empty">
        <view class="empty-icon">🔍</view>
        <view>未找到结果</view>
      </view>
    </block>
  </view>

  <!-- History -->
  <view wx:if="{{!searched}}" class="section">
    <view class="history-header">
      <view class="section-title">🕐 搜索历史</view>
      <view class="clear-btn" bindtap="clearHistory">清除</view>
    </view>
    <view wx:if="{{history.length===0}}" class="empty-text">暂无搜索历史</view>
    <view wx:for="{{history}}" wx:key="*this" class="history-chip" data-q="{{item}}" bindtap="tapHistory">{{item}}</view>
  </view>
</view>
