/* 梦眠 —— 梦境守护者 主题 */
page {
  --bg: #0a0a14;
  --bg2: #101025;
  --card-bg: rgba(22,22,50,0.6);
  --hover: rgba(30,30,60,0.5);
  --bd: rgba(255,255,255,0.06);
  --bd-glow: rgba(139,156,247,0.15);
  --tx: #e8e8f2;
  --tx2: #a0a0c0;
  --tx3: #6a6a8a;
  --primary: #8b9cf7;
  --primary-soft: rgba(139,156,247,0.12);
  --accent: #8b9cf7;
  --ac-glow: rgba(139,156,247,0.3);
  --teal: #5eead4;
  --teal-soft: rgba(94,234,212,0.12);
  --teal-glow: rgba(94,234,212,0.25);
  --success: #5ee0a0;
  --warn: #f0b050;
  --danger: #f06070;
  --ac: var(--primary);
  --suc: var(--success);
  --err: var(--danger);

  background: var(--bg);
  color: var(--tx);
  font-family: -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 14px;
  line-height: 1.65;
  letter-spacing: 0.2px;
}

/* Layout */
.container { padding: 28rpx; min-height: 100vh; }
.page-title { font-size: 38rpx; font-weight: 700; margin-bottom: 36rpx; color: var(--tx); }

/* Card */
.card {
  background: var(--card-bg);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid var(--bd);
}
.section-title { font-size: 26rpx; font-weight: 600; margin-bottom: 18rpx; color: var(--tx2); }

/* Buttons */
.btn { display: flex; align-items: center; justify-content: center; padding: 18rpx 36rpx; border-radius: 20rpx; font-size: 26rpx; font-weight: 500; letter-spacing: 0.3px; border: none; transition: opacity 0.15s; }
.btn:active { opacity: 0.75; }
.btn-hover { opacity: 0.7; transform: scale(0.97); }
.btn-primary { background: linear-gradient(135deg, var(--primary), #7a8ae0); color: #fff; }
.btn-secondary { background: var(--hover); color: var(--tx2); border: 1rpx solid var(--bd); }
.btn-danger { background: var(--danger); color: #fff; }
.btn-sm { padding: 10rpx 24rpx; font-size: 22rpx; }

/* Form */
.input { width: 100%; padding: 18rpx 24rpx; background: rgba(20,20,45,0.7); border: 1rpx solid var(--bd); border-radius: 16rpx; color: var(--tx); font-size: 26rpx; box-sizing: border-box; }
.form-group { margin-bottom: 22rpx; }
.form-group label { display: block; margin-bottom: 10rpx; font-size: 24rpx; color: var(--tx2); }

/* Shared */
.badge { display: inline-block; padding: 4rpx 14rpx; background: var(--primary-soft); color: var(--primary); border-radius: 16rpx; font-size: 20rpx; font-weight: 500; border: 1rpx solid var(--bd-glow); }
.empty-state { text-align: center; padding: 80rpx 40rpx; color: var(--tx3); font-size: 26rpx; }
.grid-2 { display: flex; flex-wrap: wrap; gap: 14rpx; }
.grid-2 > view { flex: 1; min-width: calc(50% - 7rpx); }

/* Progress bar */
.prog-bar { width: 100%; height: 8px; background: var(--hover); border-radius: 4px; overflow: hidden; }
.prog-fill { height: 100%; background: linear-gradient(90deg, var(--primary), var(--teal)); border-radius: 4px; transition: width 0.5s; }

/* Stat card */
.stat-card { text-align: center; }
.stat-label { font-size: 22rpx; color: var(--tx3); margin-bottom: 8rpx; }
.stat-val { font-size: 52rpx; font-weight: 700; }

/* Tip */
.tip-card { display: flex; align-items: center; gap: 16rpx; background: linear-gradient(135deg, rgba(139,156,247,0.06), rgba(94,234,212,0.06)); border-color: var(--bd-glow); }
.tip-ic { font-size: 40rpx; }

/* Fold */
.fold { border: 1rpx solid var(--bd); border-radius: 16rpx; overflow: hidden; }
.fold-hd { padding: 20rpx 28rpx; display: flex; justify-content: space-between; align-items: center; font-size: 26rpx; color: var(--tx2); }
.fold-bd { padding: 0 20rpx 20rpx; }
.fold-bd-hidden { display: none; }

/* Onboard */
.onboard-opt { padding: 18rpx 28rpx; border: 1rpx solid var(--bd); border-radius: 16rpx; background: transparent; color: var(--tx2); font-size: 26rpx; margin-bottom: 8rpx; }
.onboard-opt-sel { border-color: var(--primary); background: var(--primary-soft); color: var(--primary); }
.onboard-err { color: var(--err); font-size: 24rpx; padding: 16rpx 24rpx; background: rgba(240,96,112,0.1); border-radius: 16rpx; margin-bottom: 20rpx; }

/* Overlay */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.65); z-index: 1000; display: flex; align-items: center; justify-content: center; }
.modal-sheet { background: var(--card-bg); border: 1rpx solid var(--bd); border-radius: 40rpx; padding: 48rpx; width: 620rpx; max-width: 90vw; max-height: 80vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }

/* Attribute dots */
.attr-dot { display: inline-block; font-size: 24rpx; margin: 0 2rpx; }
